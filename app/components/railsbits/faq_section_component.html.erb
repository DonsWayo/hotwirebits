<section class="<%= container_classes %>" <%= tag.attributes(@extra_attrs) %>>
  <div class="mx-auto max-w-3xl">
    <% if @title %>
      <h2 class="text-3xl md:text-4xl font-bold text-rb-foreground text-center mb-10"><%= @title %></h2>
    <% end %>
    <div class="divide-y divide-rb-border rounded-lg border border-rb-border" data-controller="rb-accordion">
      <% @items.each_with_index do |item, index| %>
        <div>
          <button type="button"
                  class="flex w-full items-center justify-between px-6 py-4 text-left hover:bg-rb-muted/50 transition-colors"
                  data-action="click->rb-accordion#toggle"
            data-rb-accordion-target="trigger">
            <span class="text-base font-medium text-rb-foreground pr-4"><%= item[:question] %></span>
            <svg class="h-5 w-5 shrink-0 text-rb-muted-foreground transition-transform duration-200" xmlns="http://www.w3.org/2000/svg"
                 viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
            </svg>
          </button>
          <div class="hidden px-6 pb-4 text-sm text-rb-muted-foreground leading-relaxed" data-rb-accordion-target="content">
            <%= item[:answer] %>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</section>
