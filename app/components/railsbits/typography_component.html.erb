<% tag_name = (@as || :p).to_s %>
<% styles = { h1: "scroll-m-20 text-4xl font-extrabold tracking-tight lg:text-5xl", h2: "scroll-m-20 border-b border-rb-border pb-2 text-3xl font-semibold tracking-tight first:mt-0", h3: "scroll-m-20 text-2xl font-semibold tracking-tight", h4: "scroll-m-20 text-xl font-semibold tracking-tight", h5: "scroll-m-20 text-lg font-semibold tracking-tight", h6: "scroll-m-20 text-base font-semibold tracking-tight", p: "leading-7 [&:not(:first-child)]:mt-6", lead: "text-xl text-rb-muted-foreground", large: "text-lg font-semibold", small: "text-sm font-medium leading-none", muted: "text-sm text-rb-muted-foreground", blockquote: "mt-6 border-l-2 border-rb-border pl-6 italic", code: "relative rounded bg-rb-muted px-[0.3rem] py-[0.2rem] font-mono text-sm font-semibold", list: "my-6 ml-6 list-disc [&>li]:mt-2", mark: "bg-yellow-200 dark:bg-yellow-800 px-0.5 rounded" } %>
<% style_key = (@as || :p).to_sym %>
