<div class="<%= container_classes %>" <%= tag.attributes(@extra_attrs) %>>
  <ul class="list-none p-0 m-0" data-controller="rb-tree">
    <% @items.each do |item| %>
      <%= render RailsBits::TreeViewNodeComponent.new(item: item) %>
    <% end %>
  </ul>
</div>
<template data-rb-tree-target="template">
  <li class="list-none">
    <div class="flex items-center gap-1.5 px-2 py-1 rounded-md hover:bg-rb-muted cursor-pointer text-sm"
         data-action="click->rb-tree#toggle">
      <%# Placeholder — rendered inline via node component %>
    </div>
  </li>
</template>
