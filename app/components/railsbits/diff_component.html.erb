<div class="<%= container_classes %>" <%= tag.attributes(@extra_attrs) %>>
  <div class="rounded-lg border border-rb-border overflow-hidden">
    <div class="px-4 py-2 bg-rb-muted border-b border-rb-border">
      <span class="text-xs font-medium text-rb-destructive"><%= @before_label %></span>
    </div>
    <div class="p-4 text-sm font-mono">
      <% if before_slot? %>
        <%= before_slot %>
      <% end %>
    </div>
  </div>
  <div class="rounded-lg border border-rb-border overflow-hidden">
    <div class="px-4 py-2 bg-rb-muted border-b border-rb-border">
      <span class="text-xs font-medium text-rb-success"><%= @after_label %></span>
    </div>
    <div class="p-4 text-sm font-mono">
      <% if after_slot? %>
        <%= after_slot %>
      <% end %>
    </div>
  </div>
</div>
