<section class="<%= container_classes %>" <%= tag.attributes(@extra_attrs) %>>
  <div class="mx-auto max-w-5xl rounded-2xl bg-rb-accent p-8 md:p-12">
    <div class="flex flex-col <%= @variant == :with_image && @image_url ? 'md:flex-row items-center gap-8' : 'items-center text-center' %>">
      <div class="flex-1 <%= 'max-w-xl' unless @variant == :with_image %>">
        <h2 class="text-2xl md:text-3xl font-bold text-rb-accent-foreground"><%= @title %></h2>
        <% if @description %>
          <p class="mt-3 text-rb-accent-foreground/80"><%= @description %></p>
        <% end %>
        <% if @primary_cta || @secondary_cta %>
          <div class="mt-6 flex flex-wrap gap-3 <%= 'justify-center' unless @variant == :with_image %>">
            <% if @primary_cta %>
              <a href="<%= @primary_cta[:href] %>"
                 class="inline-flex items-center justify-center rounded-lg bg-rb-primary text-rb-primary-foreground h-11 px-6 text-sm font-medium shadow-sm hover:bg-rb-primary/90 transition-colors">
                <%= @primary_cta[:label] %>
              </a>
            <% end %>
            <% if @secondary_cta %>
              <a href="<%= @secondary_cta[:href] %>"
                 class="inline-flex items-center justify-center rounded-lg border border-rb-border bg-rb-background h-11 px-6 text-sm font-medium text-rb-foreground hover:bg-rb-muted transition-colors">
                <%= @secondary_cta[:label] %>
              </a>
            <% end %>
          </div>
        <% end %>
      </div>
      <% if @variant == :with_image && @image_url %>
        <div class="w-full md:w-1/3 shrink-0">
          <img src="<%= @image_url %>" alt="" class="rounded-xl w-full object-cover">
        </div>
      <% end %>
    </div>
  </div>
</section>
