<button type="button"
        class="<%= button_classes %>"
        data-controller="rb-burger"
        data-rb-burger-open-value="<%= @open %>"
        data-action="click->rb-burger#toggle"
  aria-label="Toggle menu"
  aria-expanded="<%= @open %>"
  <%= tag.attributes(@extra_attrs) %>>
  <span class="relative flex flex-col items-center justify-center gap-1">
    <span class="<%= line_classes %>"
          data-rb-burger-target="top"
          style="<%= @open ? 'transform: translateY(6px) rotate(45deg)' : '' %>"></span>
    <span class="<%= line_classes %>"
          data-rb-burger-target="middle"
          style="<%= @open ? 'opacity: 0' : '' %>"></span>
    <span class="<%= line_classes %>"
          data-rb-burger-target="bottom"
          style="<%= @open ? 'transform: translateY(-6px) rotate(-45deg)' : '' %>"></span>
  </span>
</button>
