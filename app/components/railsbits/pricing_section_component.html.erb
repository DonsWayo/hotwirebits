<section class="<%= container_classes %>" <%= tag.attributes(@extra_attrs) %>>
  <div class="mx-auto max-w-5xl">
    <% if @title || @subtitle %>
      <div class="text-center mb-12">
        <% if @title %>
          <h2 class="text-3xl md:text-4xl font-bold text-rb-foreground"><%= @title %></h2>
        <% end %>
        <% if @subtitle %>
          <p class="mt-3 text-lg text-rb-muted-foreground"><%= @subtitle %></p>
        <% end %>
      </div>
    <% end %>
    <div class="grid gap-6 grid-cols-1 sm:grid-cols-2 lg:grid-cols-<%= [@plans.size, 4].min %>">
      <% @plans.each do |plan| %>
        <div class="flex flex-col rounded-xl border <%= plan[:highlighted] ? 'border-rb-primary shadow-lg ring-1 ring-rb-primary' : 'border-rb-border' %> bg-rb-card p-6">
          <% if plan[:highlighted] %>
            <span class="self-start rounded-full bg-rb-primary text-rb-primary-foreground px-3 py-1 text-xs font-medium mb-2">Popular</span>
          <% end %>
          <h3 class="text-lg font-semibold text-rb-foreground"><%= plan[:name] %></h3>
          <div class="mt-3 flex items-baseline gap-1">
            <span class="text-4xl font-bold text-rb-foreground"><%= plan[:price] %></span>
            <% if plan[:period] %>
              <span class="text-sm text-rb-muted-foreground">/<%= plan[:period] %></span>
            <% end %>
          </div>
          <% if plan[:features] %>
            <ul class="mt-6 space-y-3 flex-1">
              <% plan[:features].each do |feature| %>
                <li class="flex items-start gap-2 text-sm text-rb-foreground">
                  <svg class="h-4 w-4 text-rb-success shrink-0 mt-0.5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <polyline points="20 6 9 17 4 12"/>
                  </svg>
                  <%= feature %>
                </li>
              <% end %>
            </ul>
          <% end %>
          <a href="<%= plan[:cta_href] || '#' %>"
             class="mt-6 inline-flex items-center justify-center rounded-lg h-10 px-4 text-sm font-medium transition-colors <%= plan[:highlighted] ? 'bg-rb-primary text-rb-primary-foreground hover:bg-rb-primary/90' : 'border border-rb-border text-rb-foreground hover:bg-rb-muted' %>">
            <%= plan[:cta_label] || 'Get Started' %>
          </a>
        </div>
      <% end %>
    </div>
  </div>
</section>
