<div data-controller="rb-dialog"
     data-rb-dialog-open-value="<%= @open %>">
  <div class="fixed inset-0 z-50 bg-black/80 data-[state=open]:animate-in data-[state=closed]:animate-out data-[state=closed]:fade-out-0 data-[state=open]:fade-in-0"
       data-state="<%= @open ? 'open' : 'closed' %>"
       data-rb-dialog-target="overlay"
       aria-hidden="true"></div>
  <div class="fixed left-1/2 top-1/2 z-50 grid w-full max-w-lg -translate-x-1/2 -translate-y-1/2 gap-4 border border-rb-border bg-rb-background p-6 shadow-lg duration-200 data-[state=open]:animate-in data-[state=closed]:animate-out data-[state=closed]:fade-out-0 data-[state=open]:fade-in-0 data-[state=closed]:zoom-out-95 data-[state=open]:zoom-in-95 data-[state=closed]:slide-out-to-left-1/2 data-[state=closed]:slide-out-to-top-[48%] data-[state=open]:slide-in-from-left-1/2 data-[state=open]:slide-in-from-top-[48%] rounded-lg"
       data-state="<%= @open ? 'open' : 'closed' %>"
       data-rb-dialog-target="panel"
       role="alertdialog"
       aria-modal="true"
       <%= tag.attributes(@extra_attrs) %>>
    <div class="flex flex-col space-y-2 text-center sm:text-left">
      <% if @title %>
        <h2 class="text-lg font-semibold tracking-tight"><%= @title %></h2>
      <% end %>
      <% if @description %>
        <p class="text-sm text-rb-muted-foreground"><%= @description %></p>
      <% end %>
    </div>
    <div class="flex flex-col-reverse sm:flex-row sm:justify-end sm:space-x-2">
      <button type="button" class="<%= cancel_classes %>" data-action="click->rb-dialog#close">
        <%= cancel_action? ? cancel_action : @cancel_label %>
      </button>
      <button type="button" class="<%= confirm_classes %>">
        <%= confirm_action? ? confirm_action : @confirm_label %>
      </button>
    </div>
  </div>
</div>
