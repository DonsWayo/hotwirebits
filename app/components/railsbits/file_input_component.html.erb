<label class="<%= label_classes %>">
  <input type="file" name="<%= @name %>" accept="<%= @accept %>" <%= 'multiple' if @multiple %> <%= 'disabled' if @disabled %> class="sr-only" <%= tag.attributes(@extra_attrs) %>>
  <span class="flex items-center gap-2">
    <svg class="h-4 w-4 text-rb-muted-foreground" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12"/></svg>
    <span class="text-sm"><%= @label %></span>
  </span>
</label>
