<div class="<%= container_classes %>" <%= tag.attributes(@extra_attrs) %>>
  <div class="flex items-center justify-between px-4 py-2 border-b border-rb-border">
    <span class="text-xs font-medium text-rb-muted-foreground"><%= @language || 'code' %></span>
    <% if @copyable %>
      <button
        type="button"
        class="text-xs text-rb-muted-foreground hover:text-rb-foreground transition-colors"
        data-controller="rb-clipboard"
        data-action="click->rb-clipboard#copy"
        data-rb-clipboard-text-value="<%= @code %>"
        >
        Copy
      </button>
    <% end %>
  </div>
  <pre class="overflow-x-auto p-4 text-sm"><code><%= @code %></code></pre>
</div>
