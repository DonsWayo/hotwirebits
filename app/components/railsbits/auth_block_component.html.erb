<div class="<%= container_classes %>" <%= tag.attributes(@extra_attrs) %>>
  <div class="rounded-xl border border-rb-border bg-rb-card p-8 shadow-sm">
    <div class="text-center mb-6">
      <h2 class="text-2xl font-bold text-rb-foreground">
        <%= sign_up? ? 'Create an account' : 'Welcome back' %>
      </h2>
      <p class="mt-1 text-sm text-rb-muted-foreground">
        <%= sign_up? ? 'Sign up to get started' : 'Sign in to your account' %>
      </p>
    </div>
    <% if @providers.any? %>
      <div class="space-y-2 mb-6">
        <% @providers.each do |provider| %>
          <button type="button"
                  class="w-full inline-flex items-center justify-center gap-2 rounded-lg border border-rb-border bg-rb-background h-10 px-4 text-sm font-medium text-rb-foreground hover:bg-rb-muted transition-colors">
            <%= provider_icon(provider)&.html_safe %>
            Continue with <%= provider.to_s.capitalize %>
          </button>
        <% end %>
      </div>
      <div class="relative mb-6">
        <div class="absolute inset-0 flex items-center">
          <div class="w-full border-t border-rb-border"></div>
        </div>
        <div class="relative flex justify-center text-xs"><span class="bg-rb-card px-2 text-rb-muted-foreground">or continue with email</span></div>
      </div>
    <% end %>
    <form action="<%= @action_url %>" method="post" class="space-y-4">
      <% if sign_up? %>
        <div>
          <label for="name" class="block text-sm font-medium text-rb-foreground mb-1.5">Name</label>
          <input type="text" name="name" id="name" placeholder="Your name"
                 class="w-full h-10 rounded-lg border border-rb-border bg-rb-background px-3 text-sm text-rb-foreground placeholder:text-rb-muted-foreground focus:outline-none focus:ring-2 focus:ring-rb-ring">
        </div>
      <% end %>
      <div>
        <label for="email" class="block text-sm font-medium text-rb-foreground mb-1.5">Email</label>
        <input type="email" name="email" id="email" placeholder="you@example.com" required
               class="w-full h-10 rounded-lg border border-rb-border bg-rb-background px-3 text-sm text-rb-foreground placeholder:text-rb-muted-foreground focus:outline-none focus:ring-2 focus:ring-rb-ring">
      </div>
      <div>
        <div class="flex items-center justify-between mb-1.5">
          <label for="password" class="block text-sm font-medium text-rb-foreground">Password</label>
          <% if @show_forgot && !sign_up? %>
            <a href="/users/password/new" class="text-xs text-rb-primary hover:underline">Forgot password?</a>
          <% end %>
        </div>
        <input type="password" name="password" id="password" placeholder="••••••••" required
               class="w-full h-10 rounded-lg border border-rb-border bg-rb-background px-3 text-sm text-rb-foreground placeholder:text-rb-muted-foreground focus:outline-none focus:ring-2 focus:ring-rb-ring">
      </div>
      <button type="submit"
              class="w-full inline-flex items-center justify-center rounded-lg bg-rb-primary text-rb-primary-foreground h-10 px-4 text-sm font-medium shadow-sm hover:bg-rb-primary/90 transition-colors">
        <%= sign_up? ? 'Create account' : 'Sign in' %>
      </button>
    </form>
    <p class="mt-6 text-center text-sm text-rb-muted-foreground">
      <%= sign_up? ? 'Already have an account?' : "Don't have an account?" %>
      <a href="<%= sign_up? ? '/users/sign_in' : '/users/sign_up' %>" class="text-rb-primary hover:underline font-medium">
        <%= sign_up? ? 'Sign in' : 'Sign up' %>
      </a>
    </p>
  </div>
</div>
