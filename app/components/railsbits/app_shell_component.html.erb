<div class="flex h-screen flex-col" <%= tag.attributes(@extra_attrs) %>>
  <% if header? %>
    <header class="shrink-0 border-b border-rb-border bg-rb-background">
      <%= header %>
    </header>
  <% end %>
  <div class="flex flex-1 overflow-hidden">
    <% if sidebar? %>
      <aside class="<%= @sidebar_collapsed ? 'w-16' : 'w-64' %> shrink-0 border-r border-rb-border bg-rb-background overflow-y-auto transition-[width] duration-200">
        <%= sidebar %>
      </aside>
    <% end %>
    <main class="flex-1 overflow-y-auto bg-rb-background">
      <%= content %>
    </main>
  </div>
  <% if footer? %>
    <footer class="shrink-0 border-t border-rb-border bg-rb-background">
      <%= footer %>
    </footer>
  <% end %>
</div>
