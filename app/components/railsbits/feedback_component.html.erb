<div class="rounded-lg border border-rb-border bg-rb-card p-4" data-controller="rb-feedback" <%= tag.attributes(@extra_attrs) %>>
  <% if @question %>
    <p class="mb-3 text-sm font-medium"><%= @question %></p>
  <% end %>
  <% case @type %>
  <% when :thumbs %>
    <div class="flex items-center gap-2">
      <button type="button" data-action="click->rb-feedback#select" data-rb-feedback-target="option" data-value="up"
        class="inline-flex h-9 w-9 items-center justify-center rounded-md border border-rb-input bg-rb-background text-sm transition-colors hover:bg-rb-accent hover:text-rb-accent-foreground">
        <svg class="h-5 w-5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6.633 10.5c.806 0 1.533-.446 2.031-1.08a9.041 9.041 0 012.861-2.4c.723-.384 1.35-.956 1.653-1.715a4.498 4.498 0 00.322-1.672V3a.75.75 0 01.75-.75A2.25 2.25 0 0116.5 4.5c0 1.152-.26 2.243-.723 3.218-.266.558.107 1.282.725 1.282h3.126c1.026 0 1.945.694 2.054 1.715.045.422.068.85.068 1.285a11.95 11.95 0 01-2.649 7.521c-.388.482-.987.729-1.605.729H13.48c-.483 0-.964-.078-1.423-.23l-3.114-1.04a4.501 4.501 0 00-1.423-.23H5.904M14.25 9h2.25M5.904 18.75c.083.205.173.405.27.602.197.4-.078.898-.523.898h-.908c-.889 0-1.713-.518-1.972-1.368a12 12 0 01-.521-3.507c0-1.553.295-3.036.831-4.398C3.387 10.203 4.167 9.75 5 9.75h1.053c.472 0 .745.556.5.96a8.958 8.958 0 00-1.302 4.665c0 1.194.232 2.333.654 3.375z"/>
        </svg>
      </button>
      <button type="button" data-action="click->rb-feedback#select" data-rb-feedback-target="option" data-value="down"
        class="inline-flex h-9 w-9 items-center justify-center rounded-md border border-rb-input bg-rb-background text-sm transition-colors hover:bg-rb-accent hover:text-rb-accent-foreground">
        <svg class="h-5 w-5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M7.5 15h2.25m8.024-9.75c.011.05.028.1.052.148.591 1.2.924 2.55.924 3.977a8.96 8.96 0 01-.999 4.125m.023-8.25c-.076-.365.183-.75.575-.75h.908c.889 0 1.713.518 1.972 1.368.339 1.11.521 2.287.521 3.507 0 1.553-.295 3.036-.831 4.398C20.613 14.547 19.833 15 19 15h-1.053c-.472 0-.745-.556-.5-.96a8.95 8.95 0 00.303-.54m.023-8.25H16.48a4.5 4.5 0 01-1.423-.23l-3.114-1.04a4.5 4.5 0 00-1.423-.23H5.904c-.889 0-1.713.518-1.972 1.368a11.976 11.976 0 00-.521 3.507c0 1.553.295 3.036.831 4.398.393.837.999 1.287 1.605 1.287h3.126c1.026 0 1.945-.694 2.054-1.715.045-.422.068-.85.068-1.285a11.95 11.95 0 00-2.649-7.521c-.388-.482-.107-1.282.725-1.282h3.126z"/>
        </svg>
      </button>
    </div>
  <% when :stars %>
    <div class="flex items-center gap-1" data-rb-feedback-target="starContainer">
      <% 5.times do |i| %>
        <button type="button" data-action="click->rb-feedback#selectStar" data-value="<%= i + 1 %>"
          class="text-rb-muted-foreground transition-colors hover:text-rb-warning">
          <svg class="h-6 w-6" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.563.563 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z"/>
          </svg>
        </button>
      <% end %>
    </div>
  <% when :emoji %>
    <div class="flex items-center gap-1">
      <% emoji_options.each_with_index do |emoji, i| %>
        <button type="button" data-action="click->rb-feedback#select" data-rb-feedback-target="option" data-value="<%= i + 1 %>"
          class="inline-flex h-9 w-9 items-center justify-center rounded-md border border-rb-input bg-rb-background text-lg transition-colors hover:bg-rb-accent">
          <%= emoji %>
        </button>
      <% end %>
    </div>
  <% when :nps %>
    <div class="flex items-center gap-1">
      <% nps_range.each do |n| %>
        <button type="button" data-action="click->rb-feedback#select" data-rb-feedback-target="option" data-value="<%= n %>"
          class="inline-flex h-8 w-8 items-center justify-center rounded-md border border-rb-input bg-rb-background text-xs font-medium transition-colors hover:bg-rb-primary hover:text-rb-primary-foreground">
          <%= n %>
        </button>
      <% end %>
    </div>
  <% end %>
</div>
