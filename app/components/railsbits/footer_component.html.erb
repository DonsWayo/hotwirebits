<footer class="border-t border-rb-border bg-rb-background" <%= tag.attributes(@extra_attrs) %>>
  <div class="mx-auto max-w-screen-xl px-4 py-12">
    <div class="grid gap-8 sm:grid-cols-2 md:grid-cols-<%= [@columns.size + 1, 4].min %>">
      <div>
        <% if @brand %>
          <a href="/" class="text-lg font-semibold text-rb-foreground"><%= @brand %></a>
        <% end %>
        <% if @social_links.any? %>
          <div class="mt-4 flex gap-4">
            <% @social_links.each do |link| %>
              <a href="<%= link[:href] %>" class="text-rb-muted-foreground hover:text-rb-foreground transition-colors" aria-label="<%= link[:label] %>" target="_blank" rel="noopener noreferrer">
                <% if link[:icon] %>
                  <span class="h-5 w-5"><%= link[:icon].html_safe %></span>
                <% else %>
                  <span class="text-sm"><%= link[:label] %></span>
                <% end %>
              </a>
            <% end %>
          </div>
        <% end %>
      </div>
      <% @columns.each do |col| %>
        <div>
          <h3 class="mb-3 text-sm font-semibold text-rb-foreground"><%= col[:title] %></h3>
          <ul class="space-y-2">
            <% col[:links].each do |link| %>
              <li>
                <a href="<%= link[:href] %>" class="text-sm text-rb-muted-foreground hover:text-rb-foreground transition-colors"><%= link[:label] %></a>
              </li>
            <% end %>
          </ul>
        </div>
      <% end %>
    </div>
  </div>
  <% if @copyright %>
    <div class="border-t border-rb-border">
      <div class="mx-auto max-w-screen-xl px-4 py-4">
        <p class="text-center text-xs text-rb-muted-foreground"><%= @copyright %></p>
      </div>
    </div>
  <% end %>
</footer>
