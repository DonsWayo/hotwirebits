<div class="relative inline-block"
     data-controller="rb-popover"
     data-rb-popover-open-value="<%= @open %>">
  <div data-action="click->rb-popover#toggle" data-rb-popover-target="trigger" class="inline-block">
    <% if trigger? %>
      <%= trigger %>
    <% else %>
      <button type="button" class="inline-flex items-center justify-center rounded-md text-sm font-medium ring-offset-rb-background transition-colors hover:bg-rb-accent hover:text-rb-accent-foreground h-9 px-3">
        Open
      </button>
    <% end %>
  </div>
  <div class="<%= popover_classes %> <%= align_classes %>"
       data-rb-popover-target="content"
       data-state="<%= @open ? 'open' : 'closed' %>"
       data-side="<%= @side %>"
       <%= tag.attributes(@extra_attrs) %>>
    <%= content %>
  </div>
</div>
