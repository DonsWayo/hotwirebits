<nav class="fixed inset-x-0 bottom-0 z-50 border-t border-rb-border bg-rb-background/95 backdrop-blur supports-[backdrop-filter]:bg-rb-background/60" <%= tag.attributes(@extra_attrs) %>>
  <div class="mx-auto flex h-16 max-w-md items-center justify-around px-6">
    <% @items.each do |item| %>
      <a href="<%= item[:href] %>"
         class="<%= merge_classes(
           'group relative flex flex-col items-center gap-1 text-xs transition-colors',
           item[:active] ? 'text-rb-primary' : 'text-rb-muted-foreground hover:text-rb-foreground'
         ) %>">
  <span class="relative">
    <% if item[:icon] %>
      <span class="h-6 w-6"><%= item[:icon].html_safe %></span>
    <% end %>
    <% if item[:badge] %>
      <span class="absolute -right-2 -top-1 flex h-4 min-w-4 items-center justify-center rounded-full bg-rb-primary px-1 text-[10px] font-medium text-rb-primary-foreground"><%= item[:badge] %></span>
    <% end %>
  </span>
  <span class="<%= item[:active] ? 'font-medium' : '' %>"><%= item[:label] %></span>
</a>
<% end %>
</div>
</nav>
