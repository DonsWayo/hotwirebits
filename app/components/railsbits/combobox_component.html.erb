<div class="relative" data-controller="rb-combobox">
  <input type="hidden" name="<%= @name %>" value="<%= @selected %>" data-rb-combobox-target="hidden">
  <input type="text" placeholder="<%= @placeholder %>" <%= 'disabled' if @disabled %> class="flex h-9 w-full rounded-md border border-rb-input bg-rb-background px-3 text-sm text-rb-foreground ring-offset-rb-background placeholder:text-rb-muted-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-rb-ring focus-visible:ring-offset-2" data-action="input->rb-combobox#search focus->rb-combobox#open click@window->rb-combobox#close" data-rb-combobox-target="input" role="combobox" aria-expanded="false" autocomplete="list" <%= tag.attributes(@extra_attrs) %>>
  <div class="absolute z-50 mt-1 w-full rounded-md border border-rb-border bg-rb-popover shadow-md hidden" data-rb-combobox-target="dropdown">
    <ul class="max-h-60 overflow-auto p-1" role="listbox">
      <% @options.each do |opt| %>
        <% value = opt.is_a?(Array) ? opt.last : opt %>
        <% label = opt.is_a?(Array) ? opt.first : opt %>
        <li class="relative flex cursor-pointer select-none items-center rounded-sm px-2 py-1.5 text-sm outline-none hover:bg-rb-accent hover:text-rb-accent-foreground" role="option" data-action="click->rb-combobox#select" data-value="<%= value %>">
          <%= label %>
        </li>
      <% end %>
    </ul>
  </div>
</div>
