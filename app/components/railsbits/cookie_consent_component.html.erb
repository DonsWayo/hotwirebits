<div class="<%= container_classes %>"
     data-controller="rb-cookie-consent"
     <%= tag.attributes(@extra_attrs) %>>
  <div class="mx-auto max-w-4xl rounded-xl border border-rb-border bg-rb-card p-4 shadow-lg">
    <div class="flex flex-col sm:flex-row items-start sm:items-center gap-4">
      <div class="flex-1">
        <p class="text-sm text-rb-foreground"><%= @message %></p>
      </div>
      <div class="flex items-center gap-2 shrink-0">
        <button type="button"
                class="rounded-lg border border-rb-border bg-rb-background h-9 px-4 text-sm font-medium text-rb-foreground hover:bg-rb-muted transition-colors"
                data-action="click->rb-cookie-consent#settings">
          <%= @settings_label %>
        </button>
        <button type="button"
                class="rounded-lg bg-rb-primary text-rb-primary-foreground h-9 px-4 text-sm font-medium hover:bg-rb-primary/90 transition-colors"
                data-action="click->rb-cookie-consent#accept">
          <%= @accept_label %>
        </button>
      </div>
    </div>
  </div>
</div>
