<div class="inline-block" <%= tag.attributes(@extra_attrs) %>>
  <% if @type == :browser %>
    <div class="flex items-center gap-2 px-4 py-2 bg-neutral-800 rounded-t-lg">
      <div class="flex gap-1.5">
        <div class="w-3 h-3 rounded-full bg-red-500"></div>
        <div class="w-3 h-3 rounded-full bg-yellow-500"></div>
        <div class="w-3 h-3 rounded-full bg-green-500"></div>
      </div>
      <div class="flex-1 mx-4">
        <div class="bg-neutral-700 rounded h-5 w-full max-w-xs"></div>
      </div>
    </div>
    <div class="<%= frame_classes %> rounded-t-none">
      <%= content %>
    </div>
  <% elsif @type == :phone %>
    <div class="<%= frame_classes %>">
      <% if @device == :iphone %>
        <div class="relative">
          <div class="absolute top-0 left-1/2 -translate-x-1/2 w-28 h-6 bg-black rounded-b-2xl z-10"></div>
          <div class="pt-6">
            <%= content %>
          </div>
        </div>
      <% else %>
        <div class="relative">
          <div class="absolute top-2 left-1/2 -translate-x-1/2 w-2 h-2 bg-neutral-700 rounded-full z-10"></div>
          <%= content %>
        </div>
      <% end %>
    </div>
  <% elsif @type == :tablet %>
    <div class="<%= frame_classes %>">
      <div class="relative">
        <div class="absolute top-2 left-1/2 -translate-x-1/2 w-2 h-2 bg-neutral-700 rounded-full z-10"></div>
        <%= content %>
      </div>
    </div>
  <% else %>
    <div class="<%= frame_classes %>">
      <div class="flex items-center gap-2 px-4 py-2 bg-neutral-800">
        <div class="flex gap-1.5">
          <div class="w-2.5 h-2.5 rounded-full bg-red-500"></div>
          <div class="w-2.5 h-2.5 rounded-full bg-yellow-500"></div>
          <div class="w-2.5 h-2.5 rounded-full bg-green-500"></div>
        </div>
      </div>
      <%= content %>
    </div>
  <% end %>
</div>
