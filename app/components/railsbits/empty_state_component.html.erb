<div class="flex flex-col items-center justify-center rounded-lg border border-dashed border-rb-border p-8 text-center" <%= tag.attributes(@extra_attrs) %>>
  <% if @icon %>
    <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-full bg-rb-muted text-rb-muted-foreground">
      <%= @icon.html_safe %>
    </div>
  <% end %>
  <% if @title %>
    <h3 class="text-lg font-semibold tracking-tight"><%= @title %></h3>
  <% end %>
  <% if @description %>
    <p class="mt-1.5 text-sm text-rb-muted-foreground max-w-sm"><%= @description %></p>
  <% end %>
  <% if @action_label && @action_href %>
    <a href="<%= @action_href %>"
       class="mt-4 inline-flex h-9 items-center justify-center rounded-md bg-rb-primary px-4 py-2 text-sm font-medium text-rb-primary-foreground ring-offset-rb-background transition-colors hover:bg-rb-primary/90 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-rb-ring focus-visible:ring-offset-2">
      <%= @action_label %>
    </a>
  <% end %>
  <%= content if content.present? %>
</div>
