<div class="<%= container_classes %>"
     data-controller="rb-kanban"
     <%= tag.attributes(@extra_attrs) %>>
  <% @columns.each do |col| %>
    <div class="w-72 shrink-0 rounded-lg border border-rb-border bg-rb-muted/30 p-3"
         data-rb-kanban-target="column"
         data-column="<%= col[:title] %>">
      <div class="flex items-center justify-between mb-3">
        <h3 class="text-sm font-semibold text-rb-foreground"><%= col[:title] %></h3>
        <span class="text-xs text-rb-muted-foreground bg-rb-muted rounded-full px-2 py-0.5">
          <%= col[:items]&.size || 0 %>
        </span>
      </div>
      <div class="space-y-2 min-h-[100px]"
           data-rb-kanban-target="list"
           data-action="dragover->rb-kanban#dragover drop->rb-kanban#drop">
        <% (col[:items] || []).each do |item| %>
          <div class="rounded-md border border-rb-border bg-rb-card p-3 shadow-sm cursor-grab active:cursor-grabbing"
               draggable="true"
               data-rb-kanban-target="card"
               data-action="dragstart->rb-kanban#dragstart dragend->rb-kanban#dragend"
            data-id="<%= item[:id] %>">
            <p class="text-sm font-medium text-rb-foreground"><%= item[:title] %></p>
            <% if item[:description] %>
              <p class="mt-1 text-xs text-rb-muted-foreground line-clamp-2"><%= item[:description] %></p>
            <% end %>
            <% if item[:tags]&.any? %>
              <div class="mt-2 flex flex-wrap gap-1">
                <% item[:tags].each do |tag| %>
                  <span class="inline-block rounded-full bg-rb-accent px-2 py-0.5 text-xs text-rb-accent-foreground"><%= tag %></span>
                <% end %>
              </div>
            <% end %>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>
</div>
