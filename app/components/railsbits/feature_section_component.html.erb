<section class="<%= container_classes %>" <%= tag.attributes(@extra_attrs) %>>
  <div class="mx-auto max-w-5xl">
    <% if @title || @subtitle %>
      <div class="text-center mb-12">
        <% if @title %>
          <h2 class="text-3xl md:text-4xl font-bold text-rb-foreground"><%= @title %></h2>
        <% end %>
        <% if @subtitle %>
          <p class="mt-3 text-lg text-rb-muted-foreground max-w-2xl mx-auto"><%= @subtitle %></p>
        <% end %>
      </div>
    <% end %>
    <div class="<%= grid_classes %>">
      <% @features.each do |feature| %>
        <div class="flex flex-col gap-3 rounded-lg border border-rb-border bg-rb-card p-6">
          <% if feature[:icon] %>
            <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-rb-accent text-rb-accent-foreground shrink-0">
              <span class="h-5 w-5"><%= feature[:icon].html_safe %></span>
            </div>
          <% end %>
          <h3 class="text-base font-semibold text-rb-foreground"><%= feature[:title] %></h3>
          <p class="text-sm text-rb-muted-foreground leading-relaxed"><%= feature[:description] %></p>
        </div>
      <% end %>
    </div>
  </div>
</section>
