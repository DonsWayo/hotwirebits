<button type="button"
        class="inline-flex items-center gap-1.5 rounded-full px-3 py-1.5 text-sm font-medium transition-colors cursor-pointer <%= @liked ? 'text-hw-destructive bg-hw-destructive/10 hover:bg-hw-destructive/20' : 'text-hw-muted-foreground hover:bg-hw-accent hover:text-hw-accent-foreground' %>"
        data-controller="hw-like"
        data-hw-like-liked-value="<%= @liked %>"
        data-action="click->hw-like#toggle"
  aria-pressed="<%= @liked %>"
  <%= tag.attributes(@extra_attrs) %>>
  <% if @name %>
    <input type="hidden" name="<%= @name %>" value="<%= @liked %>" data-hw-like-target="input">
  <% end %>
  <svg class="<%= icon_size %>" data-hw-like-target="icon" xmlns="http://www.w3.org/2000/svg" fill="<%= @liked ? 'currentColor' : 'none' %>" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
    <path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/>
  </svg>
  <span data-hw-like-target="count"><%= @count %></span>
</button>
