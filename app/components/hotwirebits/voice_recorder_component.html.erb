<div data-controller="hw-voice-recorder"
     data-hw-voice-recorder-max-duration-value="<%= @max_duration %>"
     data-hw-voice-recorder-format-value="<%= @format %>"
     <%= tag.attributes(@extra_attrs) %>>
  <div class="flex items-center gap-3">
    <button type="button"
            class="inline-flex h-10 w-10 items-center justify-center rounded-full border border-hw-input bg-hw-background text-hw-muted-foreground hover:bg-hw-accent hover:text-hw-accent-foreground transition-colors cursor-pointer"
            data-hw-voice-recorder-target="recordBtn"
            data-action="click->hw-voice-recorder#toggle"
      aria-label="Record">
      <svg class="h-5 w-5" data-hw-voice-recorder-target="micIcon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M19 11a7 7 0 01-7 7m0 0a7 7 0 01-7-7m7 7v4m0 0H8m4 0h4m-4-8a3 3 0 01-3-3V5a3 3 0 116 0v6a3 3 0 01-3 3z"/>
      </svg>
      <svg class="h-5 w-5 hidden" data-hw-voice-recorder-target="stopIcon" xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 24 24">
        <rect x="6" y="6" width="12" height="12" rx="2"/>
      </svg>
    </button>
    <div class="flex-1">
      <div class="flex items-center gap-2">
        <span class="text-sm text-hw-muted-foreground" data-hw-voice-recorder-target="status">Click to record</span>
        <span class="text-sm font-mono text-hw-foreground hidden" data-hw-voice-recorder-target="timer">0:00</span>
      </div>
      <div class="mt-1 w-full h-1 rounded-full bg-hw-muted overflow-hidden">
        <div class="h-full bg-hw-primary rounded-full transition-all" data-hw-voice-recorder-target="progress" style="width: 0%;"></div>
      </div>
    </div>
  </div>
  <input type="hidden" name="<%= @name %>" data-hw-voice-recorder-target="input">
</div>
