<div class="rounded-xl border border-hw-border bg-white" <%= tag.attributes(@extra_attrs) %>>
  <div class="border-b border-hw-border px-6 py-4">
    <h2 class="text-lg font-semibold text-hw-foreground">Shopping Cart (<%= @items.size %>)</h2>
  </div>
  <% if @items.empty? %>
    <div class="flex flex-col items-center justify-center px-6 py-12 text-center">
      <svg class="mb-3 h-12 w-12 text-hw-muted-foreground/40" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 3h1.386c.51 0 .955.343 1.087.835l.383 1.437M7.5 14.25a3 3 0 00-3 3h15.75m-12.75-3h11.218c1.121-2.3 2.1-4.684 2.924-7.138a60.114 60.114 0 00-16.536-1.84M7.5 14.25L5.106 5.272M6 20.25a.75.75 0 11-1.5 0 .75.75 0 011.5 0zm12.75 0a.75.75 0 11-1.5 0 .75.75 0 011.5 0z"/>
      </svg>
      <p class="text-sm text-hw-muted-foreground">Your cart is empty</p>
    </div>
  <% else %>
    <ul class="divide-y divide-hw-border">
      <% @items.each do |item| %>
        <li class="flex gap-4 px-6 py-4">
          <% if item[:image] %>
            <img src="<%= item[:image] %>" alt="<%= item[:name] %>" class="h-16 w-16 shrink-0 rounded-lg object-cover">
          <% end %>
          <div class="min-w-0 flex-1">
            <p class="truncate text-sm font-medium text-hw-foreground"><%= item[:name] %></p>
            <p class="mt-0.5 text-sm text-hw-muted-foreground"><%= item[:price] %></p>
            <div class="mt-2 flex items-center gap-2">
              <button type="button" class="flex h-6 w-6 items-center justify-center rounded border border-hw-border text-xs hover:bg-hw-muted">-</button>
              <span class="text-sm font-medium"><%= item[:quantity] %></span>
              <button type="button" class="flex h-6 w-6 items-center justify-center rounded border border-hw-border text-xs hover:bg-hw-muted">+</button>
            </div>
          </div>
          <button type="button" class="shrink-0 self-start text-hw-muted-foreground hover:text-red-500">
            <svg class="h-4 w-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
            </svg>
          </button>
        </li>
      <% end %>
    </ul>
    <div class="border-t border-hw-border px-6 py-4">
      <div class="flex items-center justify-between text-base font-semibold text-hw-foreground">
        <span>Total</span>
        <span><%= @total.is_a?(Numeric) ? "$#{'%.2f' % @total}" : @total %></span>
      </div>
      <button type="button" class="mt-4 w-full rounded-lg bg-hw-primary px-6 py-3 text-sm font-semibold text-hw-primary-foreground hover:bg-hw-primary/90">
        Checkout
      </button>
    </div>
  <% end %>
</div>
