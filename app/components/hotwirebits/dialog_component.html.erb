<div data-controller="hw-dialog"
     data-hw-dialog-open-value="<%= @open %>"
     <%= tag.attributes(@extra_attrs) %>>
  <div class="<%= overlay_classes %>"
       data-state="<%= @open ? 'open' : 'closed' %>"
       data-hw-dialog-target="overlay"
       data-action="click->hw-dialog#close"
    aria-hidden="true"></div>
  <div class="<%= dialog_classes %>"
       data-state="<%= @open ? 'open' : 'closed' %>"
       data-hw-dialog-target="panel"
       role="dialog"
       aria-modal="true"
       aria-labelledby="<%= @title ? 'dialog-title' : nil %>">
    <div class="flex flex-col space-y-1.5 text-center sm:text-left">
      <% if header? %>
        <%= header %>
      <% elsif @title %>
        <h2 id="dialog-title" class="text-lg font-semibold leading-none tracking-tight"><%= @title %></h2>
      <% end %>
    </div>
    <div class="text-sm text-hw-muted-foreground">
      <%= content %>
    </div>
    <% if footer? %>
      <div class="flex flex-col-reverse sm:flex-row sm:justify-end sm:space-x-2">
        <%= footer %>
      </div>
    <% end %>
    <% if @closable %>
      <button type="button"
              class="absolute right-4 top-4 rounded-sm opacity-70 ring-offset-hw-background transition-opacity hover:opacity-100 focus:outline-none focus:ring-2 focus:ring-hw-ring focus:ring-offset-2 disabled:pointer-events-none"
              data-action="click->hw-dialog#close">
        <svg class="h-4 w-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
        </svg>
        <span class="sr-only">Close</span>
      </button>
    <% end %>
  </div>
</div>
