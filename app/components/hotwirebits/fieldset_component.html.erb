<fieldset class="<%= fieldset_classes %>" <%= 'disabled' if @disabled %> <%= tag.attributes(@extra_attrs) %>>
  <% if @legend %>
    <legend class="text-sm font-medium text-hw-foreground"><%= @legend %></legend>
  <% end %>
  <% if @description %>
    <p class="text-xs text-hw-muted-foreground mt-1 mb-3"><%= @description %></p>
  <% end %>
  <div class="space-y-3">
    <%= content %>
  </div>
</fieldset>
