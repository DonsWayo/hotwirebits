<div data-controller="hw-month-picker" class="space-y-3" <%= tag.attributes(@extra_attrs) %>>
  <input type="hidden" name="<%= @name %>" value="<%= @value %>" data-hw-month-picker-target="hidden">
  <div class="flex items-center justify-between gap-2">
    <button type="button" class="inline-flex h-8 w-8 items-center justify-center rounded-md hover:bg-hw-accent transition-colors" data-action="click->hw-month-picker#prevYear">
      <svg class="h-4 w-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
    </button>
    <span class="text-sm font-medium" data-hw-month-picker-target="year"><%= current_year %></span>
    <button type="button" class="inline-flex h-8 w-8 items-center justify-center rounded-md hover:bg-hw-accent transition-colors" data-action="click->hw-month-picker#nextYear">
      <svg class="h-4 w-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
    </button>
  </div>
  <div class="grid grid-cols-3 gap-1">
    <% MONTHS.each_with_index do |month, i| %>
      <button type="button"
              class="<%= merge_classes(
                'rounded-md px-2 py-1.5 text-sm transition-colors hover:bg-hw-accent',
                (i + 1) == current_month ? 'bg-hw-primary text-hw-primary-foreground hover:bg-hw-primary/90' : ''
              ) %>"
              data-action="click->hw-month-picker#select"
        data-month="<%= i + 1 %>">
        <%= month[0..2] %>
      </button>
    <% end %>
  </div>
</div>
