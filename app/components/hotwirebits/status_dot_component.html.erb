<span class="relative inline-flex items-center gap-2" <%= tag.attributes(@extra_attrs) %>>
  <span class="relative inline-flex">
    <span class="<%= dot_classes %>"></span>
    <% if @with_pulse %>
      <span class="absolute inline-flex h-full w-full animate-ping rounded-full opacity-75 <%= STATUSES[@status] || 'bg-hw-success' %>"></span>
    <% end %>
  </span>
  <% if @label %>
    <span class="text-sm"><%= @label %></span>
  <% end %>
</span>
