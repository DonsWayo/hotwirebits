<div class="flex items-center justify-between px-4 py-1.5 bg-hw-muted/80 border-hw-border text-xs text-hw-muted-foreground <%= position_classes %>" <%= tag.attributes(@extra_attrs) %>>
  <% @items.each do |item| %>
    <div class="flex items-center gap-1.5">
      <% if item[:icon] %>
        <span class="h-3.5 w-3.5"><%= safe_svg(item[:icon]) %></span>
      <% end %>
      <span><%= item[:label] %></span>
      <% if item[:value] %>
        <span class="font-medium text-hw-foreground"><%= item[:value] %></span>
      <% end %>
    </div>
  <% end %>
</div>
