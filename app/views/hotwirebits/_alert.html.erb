<%# Alert component — ERB partial %>
<%# Usage: render 'hotwirebits/alert', type: :info, title: "Note", message: "Hello" %>

<%
  type        = local_assigns.fetch(:type, :info)
  title       = local_assigns[:title]
  message     = local_assigns[:message]
  icon        = local_assigns.fetch(:icon, true)
  dismissible = local_assigns.fetch(:dismissible, false)

  type_icons = {
    info:    "M11.25 11.25l.041-.02a.75.75 0 011.063.852l-.708 2.836a.75.75 0 001.063.853l.041-.021M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-9-3.75h.008v.008H12V8.25z",
    success: "M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z",
    warning: "M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z",
    error:   "M12 9v3.75m9-.75a9 9 0 11-18 0 9 9 0 0118 0zm-9 3.75h.008v.008H12v-.008z"
  }

  variant_classes = case type
                    when :success then "border-green-200 bg-green-50 text-green-800"
                    when :warning then "border-yellow-200 bg-yellow-50 text-yellow-800"
                    when :error, :destructive then "border-red-200 bg-red-50 text-red-800"
                    else "border-blue-200 bg-blue-50 text-blue-800"
                    end
  alert_cls = "relative w-full rounded-lg border p-4 #{variant_classes}"
%>

<div class="<%= alert_cls %>" data-controller="hw-alert" role="alert">
  <div class="flex items-start gap-3">
    <% if icon %>
      <svg class="mt-0.5 h-5 w-5 shrink-0" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="<%= type_icons.fetch(type, type_icons[:info]) %>"/>
      </svg>
    <% end %>
    <div class="flex-1">
      <% if title %>
        <h5 class="mb-1 font-medium leading-none tracking-tight"><%= title %></h5>
      <% end %>
      <% if message %>
        <div class="text-sm opacity-90"><%= message %></div>
      <% end %>
    </div>
    <% if dismissible %>
      <button type="button"
          class="shrink-0 rounded-sm opacity-70 ring-offset-hw-background transition-opacity hover:opacity-100 focus:outline-none focus:ring-2 focus:ring-hw-ring focus:ring-offset-2"
          data-action="click->hw-alert#dismiss">
        <svg class="h-4 w-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
        </svg>
        <span class="sr-only">Dismiss</span>
      </button>
    <% end %>
  </div>
</div>
