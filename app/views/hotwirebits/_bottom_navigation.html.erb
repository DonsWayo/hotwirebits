<%# BottomNavigation component — ERB partial %>
<%# Usage: render 'hotwirebits/bottom_navigation', ... %>

<nav class="<%= container_classes %>" <%= tag.attributes(local_assigns) %>>
  <div class="mx-auto flex max-w-lg items-center justify-around px-2 py-1">
    <% items.each do |item| %>
      <a href="<%= item[:href] %>"
         class="relative flex flex-col items-center gap-0.5 px-3 py-1.5 text-xs transition-colors
                <%= item_active?(item) ? 'text-hw-primary' : 'text-hw-muted-foreground hover:text-hw-foreground' %>">
  <% if item[:icon] %>
    <svg class="h-6 w-6" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="<%= item_active?(item) ? '2' : '1.5' %>" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" d="<%= item[:icon] %>"/>
          </svg>
        <% end %>
        <span><%= item[:label] %></span>
      <% if item[:badge] %>
        <span class="absolute -top-0.5 right-0.5 flex h-4 min-w-4 items-center justify-center rounded-full bg-hw-destructive px-1 text-[10px] font-bold text-hw-primary-foreground">
          <%= item[:badge] %>
        </span>
      <% end %>
    </a>
  <% end %>
</div>
</nav>
