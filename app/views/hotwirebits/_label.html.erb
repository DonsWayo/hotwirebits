<%# Label component — ERB partial %>
<%# Usage: render 'hotwirebits/label', ... %>

<label class="<%= label_classes %>" <%= for_field ? "for='#{for_field}'" : '' %> <%= tag.attributes(local_assigns) %>>
  <%= content %>
  <% if required %><span class="text-hw-destructive"> *</span><% end %>
<% if optional %><span class="text-hw-muted-foreground font-normal text-xs ml-1">(optional)</span><% end %>
</label>
