<%# VideoPlayer component — ERB partial %>
<%# Usage: render 'hotwirebits/video_player', ... %>

<div class="<%= container_classes %>" <%= tag.attributes(local_assigns) %>>
  <video class="absolute inset-0 h-full w-full object-cover"
         src="<%= src %>"
         <% if poster %>poster="<%= poster %>"<% end %>
         <% if autoplay %>autoplay<% end %>
         <% if controls %>controls<% end %>
         preload="metadata"
         playsinline>
    Your browser does not support the video tag.
  </video>
</div>
