<%# Dialog component — ERB partial %>
<%# Usage: render 'hotwirebits/dialog', title: "Confirm", description: "Are you sure?" %>

<%
  title       = local_assigns[:title]
  description = local_assigns[:description]
  size        = local_assigns.fetch(:size, :md)
  closable    = local_assigns.fetch(:closable, true)
  open        = local_assigns.fetch(:open, false)

  size_cls = case size
             when :sm then "max-w-sm"
             when :lg then "max-w-2xl"
             when :xl then "max-w-4xl"
             when :full then "max-w-[calc(100vw-2rem)]"
             else "max-w-lg"
             end
  overlay_cls = "fixed inset-0 z-50 bg-black/80"
  dialog_cls = "fixed left-[50%] top-[50%] z-50 grid w-full #{size_cls} translate-x-[-50%] translate-y-[-50%] gap-4 border border-hw-border bg-hw-background p-6 shadow-lg sm:rounded-lg"
%>

<div data-controller="hw-dialog" data-hw-dialog-open-value="<%= open %>">
  <div class="<%= overlay_cls %>"
       data-state="<%= open ? 'open' : 'closed' %>"
       data-hw-dialog-target="overlay"
       data-action="click->hw-dialog#close"
       aria-hidden="true"></div>
  <div class="<%= dialog_cls %>"
       data-state="<%= open ? 'open' : 'closed' %>"
       data-hw-dialog-target="panel"
       role="dialog"
       aria-modal="true"
       aria-labelledby="<%= title ? 'dialog-title' : nil %>">
    <div class="flex flex-col space-y-1.5 text-center sm:text-left">
      <% if title %>
        <h2 id="dialog-title" class="text-lg font-semibold leading-none tracking-tight"><%= title %></h2>
      <% end %>
      <% if description %>
        <p class="text-sm text-hw-muted-foreground"><%= description %></p>
      <% end %>
    </div>
    <% if block_given? %>
      <div class="text-sm text-hw-muted-foreground">
        <%= yield %>
      </div>
    <% end %>
    <% if closable %>
      <button type="button"
              class="absolute right-4 top-4 rounded-sm opacity-70 ring-offset-hw-background transition-opacity hover:opacity-100 focus:outline-none focus:ring-2 focus:ring-hw-ring focus:ring-offset-2 disabled:pointer-events-none"
              data-action="click->hw-dialog#close">
        <svg class="h-4 w-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
        </svg>
        <span class="sr-only">Close</span>
      </button>
    <% end %>
  </div>
</div>
