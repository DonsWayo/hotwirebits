<%# NativeSelect component — ERB partial %>
<%# Usage: render 'hotwirebits/native_select', ... %>

<select name="<%= name %>" <%= 'disabled' if disabled %> class="<%= select_classes %>" <%= tag.attributes(local_assigns) %>>
  <option value="" disabled <%= 'selected' unless selected %>><%= placeholder %></option>
  <% options.each do |opt| %>
    <% if opt.is_a?(Array) %>
      <option value="<%= opt.last %>" <%= 'selected' if selected == opt.last %>><%= opt.first %></option>
      <% else %>
        <option value="<%= opt %>" <%= 'selected' if selected == opt %>><%= opt %></option>
        <% end %>
      <% end %>
    </select>
