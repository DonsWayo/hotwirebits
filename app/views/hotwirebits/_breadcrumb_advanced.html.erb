<%# BreadcrumbAdvanced component — ERB partial %>
<%# Usage: render 'hotwirebits/breadcrumb_advanced', ... %>

<nav aria-label="Breadcrumb" <%= tag.attributes(local_assigns) %>>
  <ol class="flex items-center flex-wrap gap-1.5 text-sm">
    <% visible_items.each_with_index do |item, idx| %>
      <li class="flex items-center gap-1.5">
  <% if idx > 0 %>
    <% if separator == :chevron %>
      <svg class="h-3.5 w-3.5 text-hw-muted-foreground" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
    <% else %>
      <span class="text-hw-muted-foreground"><%= separator_char %></span>
    <% end %>
  <% end %>
  <% if item[:collapsed] %>
    <div class="relative" data-controller="hw-dropdown">
      <button type="button"
                    class="h-6 w-8 inline-flex items-center justify-center rounded hover:bg-hw-accent text-hw-muted-foreground cursor-pointer"
                    data-action="click->hw-dropdown#toggle click@window->hw-dropdown#closeOnClickOutside">
        ...
      </button>
      <div data-hw-dropdown-target="menu" class="hidden absolute left-0 top-full mt-1 z-50 min-w-[8rem] rounded-md border border-hw-border bg-hw-popover p-1 shadow-md">
        <% items[1..items.size - (max_items || 2)].each do |collapsed_item| %>
          <a href="<%= collapsed_item[:href] %>" class="block rounded-sm px-2 py-1.5 text-sm hover:bg-hw-accent hover:text-hw-accent-foreground transition-colors">
            <%= collapsed_item[:label] %>
          </a>
        <% end %>
      </div>
    </div>
  <% elsif item[:children]&.any? %>
    <div class="relative" data-controller="hw-dropdown">
      <button type="button"
                    class="inline-flex items-center gap-1 rounded hover:bg-hw-accent px-1 py-0.5 text-hw-muted-foreground hover:text-hw-accent-foreground cursor-pointer"
                    data-action="click->hw-dropdown#toggle click@window->hw-dropdown#closeOnClickOutside">
        <%= item[:label] %>
        <svg class="h-3 w-3" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
      </button>
      <div data-hw-dropdown-target="menu" class="hidden absolute left-0 top-full mt-1 z-50 min-w-[8rem] rounded-md border border-hw-border bg-hw-popover p-1 shadow-md">
        <% item[:children].each do |child| %>
          <a href="<%= child[:href] %>" class="block rounded-sm px-2 py-1.5 text-sm hover:bg-hw-accent hover:text-hw-accent-foreground transition-colors">
            <%= child[:label] %>
          </a>
        <% end %>
      </div>
    </div>
  <% elsif item[:href] && idx != visible_items.size - 1 %>
    <a href="<%= item[:href] %>" class="text-hw-muted-foreground hover:text-hw-foreground transition-colors">
      <%= item[:label] %>
    </a>
  <% else %>
    <span class="font-medium text-hw-foreground" <%= 'aria-current="page"' if idx == visible_items.size - 1 %>><%= item[:label] %></span>
    <% end %>
  </li>
<% end %>
</ol>
</nav>
