<%# FeatureSection component — ERB partial %>
<%# Usage: render 'hotwirebits/feature_section', ... %>

<section class="<%= container_classes %>" <%= tag.attributes(local_assigns) %>>
  <div class="mx-auto max-w-5xl">
    <% if title || subtitle %>
      <div class="text-center mb-12">
        <% if title %>
          <h2 class="text-3xl md:text-4xl font-bold text-hw-foreground"><%= title %></h2>
        <% end %>
        <% if subtitle %>
          <p class="mt-3 text-lg text-hw-muted-foreground max-w-2xl mx-auto"><%= subtitle %></p>
        <% end %>
      </div>
    <% end %>
    <div class="<%= grid_classes %>">
      <% features.each do |feature| %>
        <div class="flex flex-col gap-3 rounded-lg border border-hw-border bg-hw-card p-6">
          <% if feature[:icon] %>
            <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-hw-accent text-hw-accent-foreground shrink-0">
              <span class="h-5 w-5"><%= safe_svg(feature[:icon]) %></span>
            </div>
          <% end %>
          <h3 class="text-base font-semibold text-hw-foreground"><%= feature[:title] %></h3>
          <p class="text-sm text-hw-muted-foreground leading-relaxed"><%= feature[:description] %></p>
        </div>
      <% end %>
    </div>
  </div>
</section>
