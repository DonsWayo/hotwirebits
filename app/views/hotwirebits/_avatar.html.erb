<%# Avatar component — ERB partial %>
<%# Usage: render 'hotwirebits/avatar', initials: "JD", size: :md %>

<%
  src      = local_assigns[:src]
  alt      = local_assigns.fetch(:alt, "")
  initials = local_assigns[:initials]
  size     = local_assigns.fetch(:size, :md)
  status   = local_assigns[:status]

  sizes = { xs: "h-6 w-6 text-xs", sm: "h-8 w-8 text-xs", md: "h-10 w-10 text-sm", lg: "h-14 w-14 text-base", xl: "h-20 w-20 text-lg" }
  size_cls = sizes.fetch(size, "h-10 w-10 text-sm")
%>

<div class="relative inline-flex">
  <% if src %>
    <img src="<%= src %>" alt="<%= alt %>" class="<%= size_cls %> rounded-full object-cover">
  <% elsif initials %>
    <div class="<%= size_cls %> rounded-full bg-hw-muted flex items-center justify-center font-medium text-hw-muted-foreground">
      <%= initials %>
    </div>
  <% else %>
    <div class="<%= size_cls %> rounded-full bg-hw-muted flex items-center justify-center text-hw-muted-foreground">
      <svg class="h-[60%] w-[60%]" fill="currentColor" viewBox="0 0 24 24">
        <path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/>
      </svg>
    </div>
  <% end %>
  <% if status %>
    <span class="absolute block h-2.5 w-2.5 rounded-full ring-2 ring-white <%= status == :online ? 'bg-hw-success' : status == :busy ? 'bg-hw-destructive' : status == :away ? 'bg-hw-warning' : 'bg-hw-muted-foreground/60' %> -bottom-0.5 -right-0.5"></span>
  <% end %>
</div>
