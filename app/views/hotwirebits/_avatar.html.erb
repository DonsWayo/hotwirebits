<%# Avatar partial - local variables: src, alt, initials, size, status, class %>
<%
  src ||= local_assigns[:src]
  alt ||= local_assigns[:alt] || 'Avatar'
  initials ||= local_assigns[:initials]
  size ||= local_assigns[:size] || :md
  status ||= local_assigns[:status]
  extra_class ||= local_assigns[:class]

  size_classes = {
    xs: 'h-6 w-6 text-[10px]',
    sm: 'h-8 w-8 text-xs',
    md: 'h-10 w-10 text-sm',
    lg: 'h-12 w-12 text-base',
    xl: 'h-16 w-16 text-lg'
  }

  avatar_size = size_classes[size.to_sym] || size_classes[:md]

  status_classes = {
    online: 'bg-green-500',
    busy: 'bg-red-500',
    away: 'bg-yellow-500',
    offline: 'bg-gray-400'
  }
%>
<div class="relative inline-flex <%= extra_class %>">
  <% if src %>
    <img src="<%= src %>" alt="<%= alt %>" class="<%= avatar_size %> rounded-full object-cover">
  <% elsif initials %>
    <div class="<%= avatar_size %> rounded-full bg-hw-muted flex items-center justify-center font-medium text-hw-muted-foreground">
      <%= initials %>
    </div>
  <% else %>
    <div class="<%= avatar_size %> rounded-full bg-hw-muted flex items-center justify-center text-hw-muted-foreground">
      <svg class="h-[60%] w-[60%]" fill="currentColor" viewBox="0 0 24 24">
        <path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/>
      </svg>
    </div>
  <% end %>
  <% if status %>
    <span class="absolute block h-2.5 w-2.5 rounded-full ring-2 ring-white <%= status_classes[status.to_sym] || status_classes[:offline] %> -bottom-0.5 -right-0.5"></span>
  <% end %>
</div>
