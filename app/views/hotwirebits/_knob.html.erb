<%# Knob component — ERB partial %>
<%# Usage: render 'hotwirebits/knob', ... %>

<% size_px = { sm: 48, md: 64, lg: 96 }[size] || 64 %>
<% stroke = size_px / 10 %>
<% radius = (size_px - stroke) / 2.0 %>
<% circumference = 2 * Math::PI * radius %>
<% progress = ((value - min).to_f / [max - min, 1].max) * 0.75 %>
<% dashoffset = circumference * (1 - progress) %>
<% center = size_px / 2.0 %>
<% color_class = color || 'hw-primary' %>
<div class="relative inline-flex items-center justify-center" data-controller="hw-knob" <%= tag.attributes(local_assigns) %>>
  <svg width="<%= size_px %>" height="<%= size_px %>" class="-rotate-[135deg]">
    <circle cx="<%= center %>" cy="<%= center %>" r="<%= radius %>" fill="none" stroke="currentColor" stroke-width="<%= stroke %>" stroke-dasharray="<%= circumference * 0.75 %> <%= circumference * 0.25 %>" class="text-hw-muted"/>
    <circle cx="<%= center %>" cy="<%= center %>" r="<%= radius %>" fill="none" stroke="currentColor" stroke-width="<%= stroke %>" stroke-dasharray="<%= circumference * 0.75 %> <%= circumference * 0.25 %>" stroke-dashoffset="<%= dashoffset %>" stroke-linecap="round" class="text-<%= color_class %> transition-all duration-150" data-hw-knob-target="progress"/>
  </svg>
  <span class="absolute text-xs font-medium text-hw-foreground" data-hw-knob-target="value"><%= value %></span>
      <input type="range" name="<%= name %>" value="<%= value %>" min="<%= min %>" max="<%= max %>" step="<%= step %>" <%= 'disabled' if disabled %> class="absolute inset-0 opacity-0 cursor-pointer" data-action="input->hw-knob#update">
    </div>
