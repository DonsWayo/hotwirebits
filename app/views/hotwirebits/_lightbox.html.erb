<%# Lightbox component — ERB partial %>
<%# Usage: render 'hotwirebits/lightbox', ... %>

<div class="fixed inset-0 z-50 hidden items-center justify-center bg-black/90"
     data-controller="hw-lightbox"
     data-hw-lightbox-images-value="<%= images.to_json %>"
     data-hw-lightbox-index-value="<%= current_index %>"
     data-hw-lightbox-target="overlay"
     <%= tag.attributes(local_assigns) %>>
  <button type="button"
          class="absolute right-4 top-4 z-10 rounded-full bg-white/10 p-2 text-hw-primary-foreground backdrop-blur hover:bg-white/20"
          data-action="click->hw-lightbox#close">
    <svg class="h-6 w-6" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
    </svg>
  </button>
  <button type="button"
          class="absolute left-4 top-1/2 z-10 -translate-y-1/2 rounded-full bg-white/10 p-2 text-hw-primary-foreground backdrop-blur hover:bg-white/20"
          data-action="click->hw-lightbox#prev">
    <svg class="h-6 w-6" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5L8.25 12l7.5-7.5"/>
    </svg>
  </button>
  <button type="button"
          class="absolute right-4 top-1/2 z-10 -translate-y-1/2 rounded-full bg-white/10 p-2 text-hw-primary-foreground backdrop-blur hover:bg-white/20"
          data-action="click->hw-lightbox#next">
    <svg class="h-6 w-6" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5"/>
    </svg>
  </button>
  <img data-hw-lightbox-target="image" src="" alt="" class="max-h-[90vh] max-w-[90vw] object-contain rounded-lg">
  <div class="absolute bottom-4 left-1/2 -translate-x-1/2 text-sm text-hw-primary-foreground/70" data-hw-lightbox-target="counter"></div>
</div>
