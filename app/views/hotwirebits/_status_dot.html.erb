<%# StatusDot component — ERB partial %>
<%# Usage: render 'hotwirebits/status_dot', ... %>

<span class="relative inline-flex" <%= tag.attributes(local_assigns) %>>
  <span class="<%= dot_classes %>"></span>
<% if with_pulse %>
  <span class="absolute inline-flex h-full w-full animate-ping rounded-full opacity-75 <%= STATUSES[status] || 'bg-hw-success' %>"></span>
<% end %>
</span>
