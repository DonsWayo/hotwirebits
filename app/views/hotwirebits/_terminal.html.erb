<%# Terminal component — ERB partial %>
<%# Usage: render 'hotwirebits/terminal', ... %>

<div class="rounded-lg border border-hw-border bg-zinc-950 overflow-hidden font-mono text-sm" <%= tag.attributes(local_assigns) %>>
  <div class="flex items-center gap-2 px-4 py-2.5 bg-zinc-900 border-b border-zinc-800">
    <div class="flex gap-1.5">
      <div class="h-3 w-3 rounded-full bg-red-500"></div>
      <div class="h-3 w-3 rounded-full bg-yellow-500"></div>
      <div class="h-3 w-3 rounded-full bg-green-500"></div>
    </div>
    <span class="text-xs text-zinc-400 ml-2"><%= title %></span>
  </div>
  <div class="p-4 space-y-1 min-h-[100px]">
    <% lines.each do |line| %>
      <div>
        <span class="text-green-400"><%= line[:prompt] || '$' %></span>
        <span class="text-zinc-100 ml-1"><%= line[:command] %></span>
        <% if line[:output] %>
          <div class="text-zinc-400 mt-0.5 pl-0"><%= line[:output] %></div>
        <% end %>
      </div>
    <% end %>
  </div>
</div>
