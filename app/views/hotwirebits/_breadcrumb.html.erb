<%# Breadcrumb partial - local variables: items, separator, class %>
<%
  items ||= local_assigns[:items] || []
  separator ||= local_assigns[:separator] || '/'
  extra_class ||= local_assigns[:class]
%>
<nav aria-label="Breadcrumb" class="flex items-center text-sm text-hw-muted-foreground <%= extra_class %>">
  <ol class="flex items-center space-x-2">
    <% items.each_with_index do |item, idx| %>
      <% if idx > 0 %>
        <li class="text-hw-muted-foreground/50"><%= separator %></li>
      <% end %>
      <li>
        <% if item[:active] %>
          <span class="font-medium text-hw-foreground" aria-current="page"><%= item[:label] %></span>
        <% elsif item[:href] %>
          <a href="<%= item[:href] %>" class="hover:text-hw-foreground transition-colors"><%= item[:label] %></a>
        <% else %>
          <span><%= item[:label] %></span>
        <% end %>
      </li>
    <% end %>
  </ol>
</nav>
