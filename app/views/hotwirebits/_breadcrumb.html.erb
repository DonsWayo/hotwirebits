<%# Breadcrumb component — ERB partial %>
<%# Usage: render 'hotwirebits/breadcrumb', ... %>

<nav aria-label="Breadcrumb" class="<%= merge_classes('flex items-center text-sm text-hw-muted-foreground', extra_attrs.delete(:class)) %>" <%= tag.attributes(local_assigns) %>>
  <ol class="flex items-center space-x-2">
    <% items.each_with_index do |item, idx| %>
      <% if idx > 0 %>
        <li class="text-hw-muted-foreground/50"><%= separator %></li>
<% end %>
<li>
  <% if item[:active] %>
    <span class="font-medium text-hw-foreground" aria-current="page"><%= item[:label] %></span>
  <% elsif item[:href] %>
    <a href="<%= item[:href] %>" class="hover:text-hw-foreground transition-colors"><%= item[:label] %></a>
  <% else %>
    <span><%= item[:label] %></span>
  <% end %>
</li>
<% end %>
</ol>
</nav>
