<%# BrowserMockup component — ERB partial %>
<%# Usage: render 'hotwirebits/browser_mockup', ... %>

<div class="rounded-lg border border-neutral-300 overflow-hidden bg-white shadow-lg" <%= tag.attributes(local_assigns) %>>
  <div class="flex items-center gap-3 px-4 py-2.5 bg-neutral-100 border-b border-neutral-200">
    <div class="flex gap-1.5">
      <div class="h-3 w-3 rounded-full bg-red-400"></div>
      <div class="h-3 w-3 rounded-full bg-yellow-400"></div>
      <div class="h-3 w-3 rounded-full bg-green-400"></div>
    </div>
    <% if url %>
      <div class="flex-1 flex items-center">
        <div class="flex items-center gap-1.5 rounded-md bg-white border border-neutral-200 px-3 py-1 w-full max-w-sm">
          <svg class="h-3 w-3 text-neutral-400 shrink-0" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/>
          </svg>
          <span class="text-xs text-neutral-500 truncate"><%= url %></span>
        </div>
      </div>
    <% else %>
      <div class="flex-1 bg-white rounded h-6 border border-neutral-200"></div>
    <% end %>
  </div>
  <div class="min-h-[200px]"><%= content %></div>
</div>
