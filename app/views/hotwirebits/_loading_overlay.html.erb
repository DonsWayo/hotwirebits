<%# LoadingOverlay component — ERB partial %>
<%# Usage: render 'hotwirebits/loading_overlay', ... %>

<div class="relative" <%= tag.attributes(local_assigns) %>>
  <%= content %>
  <div class="absolute inset-0 z-10 flex flex-col items-center justify-center rounded-md bg-hw-background/60 backdrop-blur-[1px]">
    <svg class="<%= spinner_class %> animate-spin text-hw-primary" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
      <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
      <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
    </svg>
    <% if text %>
      <p class="mt-2 text-sm text-hw-muted-foreground"><%= text %></p>
    <% end %>
  </div>
</div>
