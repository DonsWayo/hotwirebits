<%# WindowMockup component — ERB partial %>
<%# Usage: render 'hotwirebits/window_mockup', ... %>

<div class="rounded-lg border border-hw-border overflow-hidden bg-white shadow-lg" <%= tag.attributes(local_assigns) %>>
  <div class="flex items-center justify-between px-4 py-2.5 bg-hw-muted border-b border-neutral-200">
    <div class="flex gap-1.5">
      <div class="h-3 w-3 rounded-full bg-red-400"></div>
      <div class="h-3 w-3 rounded-full bg-yellow-400"></div>
      <div class="h-3 w-3 rounded-full bg-green-400"></div>
    </div>
    <% if title %>
      <span class="text-xs text-hw-muted-foreground font-medium"><%= title %></span>
    <% end %>
    <div class="flex gap-1.5">
      <div class="h-3 w-3"></div>
      <div class="h-3 w-3"></div>
      <div class="h-3 w-3"></div>
    </div>
  </div>
  <div class="min-h-[200px] <%= 'resize overflow-auto' if resizable %>">
    <%= content %>
  </div>
</div>
