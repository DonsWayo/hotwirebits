<%# InputTags component — ERB partial %>
<%# Usage: render 'hotwirebits/input_tags', ... %>

<div class="flex flex-wrap gap-1.5 rounded-md border border-hw-input bg-hw-background p-1.5 ring-offset-hw-background focus-within:ring-2 focus-within:ring-hw-ring focus-within:ring-offset-2" data-controller="hw-tags">
  <% value.each do |v| %>
    <span class="inline-flex items-center gap-1 rounded-sm bg-hw-secondary px-1.5 py-0.5 text-xs text-hw-secondary-foreground">
      <span><%= v %></span>
      <button type="button" class="text-hw-muted-foreground hover:text-hw-foreground" data-action="click->hw-tags#remove" data-value="<%= v %>">
        <svg class="h-3 w-3" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
      </button>
    </span>
    <input type="hidden" name="<%= name %>[]" value="<%= v %>">
  <% end %>
  <input type="text" placeholder="<%= placeholder %>" <%= 'disabled' if disabled || (max && value.size >= max) %> class="flex-1 bg-transparent text-sm text-hw-foreground placeholder:text-hw-muted-foreground outline-none min-w-[80px]" data-action="keydown->hw-tags#keydown" data-hw-tags-target="input" <%= tag.attributes(local_assigns) %>>
</div>
