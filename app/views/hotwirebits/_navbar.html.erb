<%# Navbar component — ERB partial %>
<%# Usage: render 'hotwirebits/navbar', brand: "MyApp", items: [] %>

<%
  brand       = local_assigns[:brand]
  items       = local_assigns.fetch(:items, [])
  extra_class = local_assigns[:class]
  nav_cls     = ["border-b border-hw-border bg-hw-background/95 backdrop-blur supports-[backdrop-filter]:bg-hw-background/60", extra_class].compact.join(" ")
%>

<nav class="<%= nav_cls %>">
  <div class="mx-auto flex h-14 max-w-screen-xl items-center px-4">
    <% if brand %>
      <a href="/" class="mr-6 flex items-center space-x-2 font-semibold text-hw-foreground">
        <%= brand %>
      </a>
    <% end %>
    <% if items.any? %>
      <nav class="flex items-center gap-6 text-sm">
        <% items.each do |item| %>
          <a href="<%= item[:href] %>" class="transition-colors hover:text-hw-foreground <%= item[:active] ? 'text-hw-foreground font-medium' : 'text-hw-muted-foreground' %>">
            <%= item[:label] %>
          </a>
        <% end %>
      </nav>
    <% end %>
    <div class="flex flex-1 items-center justify-end gap-2">
    </div>
  </div>
</nav>
