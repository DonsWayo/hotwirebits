<%# Dropdown component — ERB partial %>
<%# Usage: render 'hotwirebits/dropdown', trigger_label: "Menu", items: [{label: "Item", href: "/"}] %>

<%
  trigger_label = local_assigns.fetch(:trigger_label, "Menu")
  items         = local_assigns.fetch(:items, [])
  align         = local_assigns.fetch(:align, :start)
  extra_class   = local_assigns[:class]

  panel_cls = "absolute z-50 min-w-[8rem] overflow-hidden rounded-md border border-hw-border bg-hw-popover p-1 text-hw-popover-foreground shadow-md #{align == :end ? 'right-0' : 'left-0'}"
%>

<div class="relative inline-block" data-controller="hw-dropdown">
  <button type="button"
          data-action="click->hw-dropdown#toggle click@window->hw-dropdown#closeOnClickOutside"
          class="inline-flex items-center justify-center rounded-md px-4 py-2 text-sm font-medium text-hw-foreground hover:bg-hw-accent transition-colors cursor-pointer">
    <%= trigger_label %>
    <svg class="ml-2 h-4 w-4 text-hw-muted-foreground" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
  </button>
  <div data-hw-dropdown-target="menu" class="<%= panel_cls %> hidden">
    <% items.each do |item| %>
      <% if item[:separator] %>
        <div class="-mx-1 my-1 h-px bg-hw-border"></div>
      <% else %>
        <a href="<%= item[:href] %>"
           class="relative flex cursor-pointer select-none items-center gap-2 rounded-sm px-2 py-1.5 text-sm outline-none transition-colors hover:bg-hw-accent hover:text-hw-accent-foreground"
           data-action="click->hw-dropdown#close">
          <span><%= item[:label] %></span>
        </a>
      <% end %>
    <% end %>
  </div>
</div>
