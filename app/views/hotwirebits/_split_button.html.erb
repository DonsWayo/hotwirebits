<%# SplitButton component — ERB partial %>
<%# Usage: render 'hotwirebits/split_button', ... %>

<div class="relative inline-flex" data-controller="hw-dropdown" <%= tag.attributes(local_assigns) %>>
  <button type="button" class="<%= button_classes %>"><%= label %></button>
  <button type="button"
          class="<%= trigger_classes %>"
          data-action="click->hw-dropdown#toggle click@window->hw-dropdown#closeOnClickOutside">
    <svg class="h-4 w-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
  </button>
  <div data-hw-dropdown-target="menu" class="hidden absolute right-0 top-full mt-1 z-50 min-w-[10rem] overflow-hidden rounded-md border border-hw-border bg-hw-popover p-1 text-hw-popover-foreground shadow-md">
    <% items.each do |item| %>
      <a href="<%= item[:href] %>"
         class="relative flex cursor-pointer select-none items-center gap-2 rounded-sm px-2 py-1.5 text-sm outline-none hover:bg-hw-accent hover:text-hw-accent-foreground transition-colors"
         data-action="click->hw-dropdown#close">
        <% if item[:icon] %>
          <span class="h-4 w-4 shrink-0"><%= safe_svg(item[:icon]) %></span>
        <% end %>
        <span><%= item[:label] %></span>
      </a>
    <% end %>
  </div>
</div>
