<%# Stat component — ERB partial %>
<%# Usage: render 'hotwirebits/stat', ... %>

<div class="<%= container_classes %>" <%= tag.attributes(local_assigns) %>>
  <div class="flex items-center justify-between">
    <p class="text-sm font-medium text-hw-muted-foreground"><%= title %></p>
    <% if icon %>
      <span class="text-hw-muted-foreground"><%= icon %></span>
    <% end %>
  </div>
  <div class="mt-2">
    <p class="text-2xl font-bold"><%= value %></p>
    <div class="flex items-center gap-2 mt-1">
      <% if trend_value %>
        <span class="text-sm font-medium <%= trend_color %>">
          <%= trend_up ? '↑' : '↓' %> <%= trend_value %>
        </span>
      <% end %>
      <% if description %>
        <span class="text-sm text-hw-muted-foreground"><%= description %></span>
      <% end %>
    </div>
  </div>
</div>
