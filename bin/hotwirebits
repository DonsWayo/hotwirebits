#!/usr/bin/env ruby
# frozen_string_literal: true

require "fileutils"

module HotwireBits
  class CLI
    VERSION = "0.1.0"

    COMPONENTS = %w[
      accordion activity_feed affix ai_chat alert alert_dialog anchor
      angle_slider animated_number app_shell aspect_ratio auth_block
      autocomplete avatar background_image badge banner bento_grid
      blog_section bottom_navigation box breadcrumb breadcrumb_advanced
      browser_mockup burger button calendar card card_heading carousel
      center chart chat_bubble checkbox checkout_form chip clipboard
      close_button code_block code_highlight code_mockup collapsible
      color_input color_picker color_swatch combobox command_bar compare
      confirm_dialog confirm_popup contact_section container context_menu
      cookie_consent cookie_settings countdown cta_section dashboard_card
      data_table data_view date_picker date_range_picker device_frame
      device_mockup dialog diff diff_view digital_signature divider
      dock_menu drag_drop_list drawer dropdown dropzone empty_cart
      empty_state error_page faq_section feature_section feedback fieldset
      file_browser file_input file_upload_progress flex float_label fluid
      flyout_menu footer form_fieldset form_group gallery grid group
      header header_section hero highlight hover3d_card hover_card
      hover_gallery icon_field ifta_label image image_compare image_zoom
      incentive indicator indicator_badge inline_edit inplace input
      input_group input_number input_otp input_tags join json_input
      kanban_board kbd knob label lightbox like_button list listbox
      loading_overlay logo_cloud logo_item mark marquee mask mega_menu
      menu menubar meter_group month_picker month_picker_input multiselect
      native_select nav_link navbar navigation_menu newsletter_section
      notification notification_bell number_formatter number_input
      order_summary org_chart page_heading pagination paginator panel
      password_input password_strength password_toggle permission_badge
      phone_input phone_mockup popover portal pricing_section product_list
      product_overview product_quickview progress progress_ring
      promo_section qr_code radio range_slider rating resizable review
      rich_text_editor scroll_area search search_input section_heading
      select semi_circle_progress separator sheet shopping_cart sidebar
      simple_grid skeleton skeleton_card slider social_share space
      speed_dial speed_dial_fab spinner split_button splitter spoiler
      stack stacked_list stat stats status status_bar status_dot
      stepper_form steps swap switch table table_of_contents tabs tag
      tag_input team_section terminal testimonial testimonials_section
      text_gradient text_rotate textarea theme_controller theme_icon
      theme_selector time_picker timeline toast toggle toggle_button
      toggle_button_group toolbar tooltip tree_view two_factor
      typing_indicator typography validator version_diff video_player
      voice_recorder window_mockup
    ].freeze

    def self.start(args)
      new.run(args)
    end

    def run(args)
      command = args.shift

      case command
      when "add"
        add(args)
      when "list"
        list
      when "init"
        init
      when "version", "--version", "-v"
        puts "hotwirebits v#{VERSION}"
      when "help", "--help", "-h", nil
        help
      else
        puts "Unknown command: #{command}"
        help
        exit 1
      end
    end

    private

    def add(components)
      if components.empty?
        puts "Usage: hotwirebits add <component> [component...]"
        puts "       hotwirebits add --all"
        exit 1
      end

      if components == ["--all"]
        components = COMPONENTS
        puts "Adding all #{components.size} components..."
      end

      components.each do |name|
        if COMPONENTS.include?(name)
          copy_component(name)
        else
          puts "  Unknown component: #{name}"
          puts "  Run 'hotwirebits list' to see available components."
        end
      end
    end

    def list
      puts "Available HotwireBits components (#{COMPONENTS.size}):"
      puts ""
      COMPONENTS.sort.each_slice(5) do |row|
        puts "  " + row.map { |c| c.ljust(22) }.join
      end
      puts ""
      puts "Usage: hotwirebits add <component>"
    end

    def init
      puts "Setting up HotwireBits in your project..."

      # Create directories
      FileUtils.mkdir_p("app/components/hotwirebits")
      FileUtils.mkdir_p("app/views/hotwirebits")
      FileUtils.mkdir_p("app/javascript/controllers/hotwirebits")
      FileUtils.mkdir_p("app/assets/stylesheets/hotwirebits")

      # Copy theme
      theme_path = "#{gem_path}/app/assets/stylesheets/hotwirebits/theme.css"
      if File.exist?(theme_path)
        FileUtils.cp(theme_path, "app/assets/stylesheets/hotwirebits/theme.css")
      end

      puts "HotwireBits initialized!"
      puts ""
      puts "Add to your layout's <head>:"
      puts '  <%= stylesheet_link_tag "hotwirebits/theme" %>'
      puts ""
      puts "Add components with:"
      puts "  hotwirebits add button card alert"
    end

    def copy_component(name)
      src_rb = "#{gem_path}/app/components/hotwirebits/#{name}_component.rb"
      src_erb = "#{gem_path}/app/components/hotwirebits/#{name}_component.html.erb"

      if File.exist?(src_rb)
        FileUtils.cp(src_rb, "app/components/hotwirebits/#{name}_component.rb")
        FileUtils.cp(src_erb, "app/components/hotwirebits/#{name}_component.html.erb") if File.exist?(src_erb)
        puts "  Added: #{name}"
      else
        puts "  Not found: #{name}"
      end
    end

    def gem_path
      @gem_path ||= File.expand_path("../..", __dir__)
    end

    def help
      puts <<~HELP
        HotwireBits CLI v#{VERSION}

        Usage:
          hotwirebits <command> [options]

        Commands:
          init                  Initialize HotwireBits in your project
          add <component...>    Add components to your project
          add --all             Add all #{COMPONENTS.size} available components
          list                  List all available components
          version               Show version
          help                  Show this help

        Examples:
          hotwirebits init
          hotwirebits add button card alert
          hotwirebits add --all
          hotwirebits list
      HELP
    end
  end
end

HotwireBits::CLI.start(ARGV) if __FILE__ == $PROGRAM_NAME
