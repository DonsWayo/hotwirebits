<h1><%= @component["name"] %></h1>
<p><%= @component["description"] %></p>
<div class="tabs">
  <div class="tab active" data-tab="preview">Preview</div>
  <div class="tab" data-tab="ruby">Ruby</div>
  <div class="tab" data-tab="erb">ERB</div>
</div>
<div id="tab-preview" class="tab-content">
  <div class="preview-box">
    <% component_class = "HotwireBits::#{@component["name"]}Component".safe_constantize %>
    <% if component_class %>
      <%= render component_class.new %>
    <% else %>
      <p style="color: var(--hw-muted-fg);">Preview not available — component may require specific props.</p>
    <% end %>
  </div>
</div>
<div id="tab-ruby" class="tab-content" style="display: none;">
  <div class="code-block">
    <button class="copy-btn" onclick="navigator.clipboard.writeText(document.getElementById('ruby-source').textContent)">Copy</button>
    <pre id="ruby-source"><%= @source_rb %></pre>
  </div>
</div>
<div id="tab-erb" class="tab-content" style="display: none;">
  <div class="code-block">
    <button class="copy-btn" onclick="navigator.clipboard.writeText(document.getElementById('erb-source').textContent)">Copy</button>
    <pre id="erb-source"><%= @source_erb %></pre>
  </div>
</div>
<a href="/<%= @component["category"] %>" style="font-size: 0.875rem; color: var(--hw-muted-fg);">&larr; Back to <%= PagesController::CATEGORIES[@component["category"]] %></a>
<script>
  document.querySelectorAll('.tab').forEach(tab => {
    tab.addEventListener('click', () => {
      document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
      document.querySelectorAll('.tab-content').forEach(c => c.style.display = 'none');
      tab.classList.add('active');
      document.getElementById('tab-' + tab.dataset.tab).style.display = 'block';
    });
  });
</script>
