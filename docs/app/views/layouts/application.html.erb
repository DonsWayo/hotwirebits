  <!-- Main -->
  <main class="hw-main">
    <%= yield %>
  </main>
  <script>
    // Theme — detect system preference
    (function(){
      const saved=localStorage.getItem('hw-theme');
      if(saved){document.documentElement.setAttribute('data-theme',saved)}
    })();

    function toggleTheme(){
      const h=document.documentElement;
      const isDark=h.getAttribute('data-theme')==='dark';
      const next=isDark?'light':'dark';
      h.setAttribute('data-theme',next);
      localStorage.setItem('hw-theme',next);
    }

    // Keyboard shortcuts
    document.addEventListener('keydown',e=>{
      if((e.metaKey||e.ctrlKey)&&e.key==='k'){e.preventDefault();document.getElementById('search-overlay').classList.toggle('open');if(document.getElementById('search-overlay').classList.contains('open')){document.getElementById('search-input').focus()}}
      if(e.key==='Escape'){document.getElementById('search-overlay').classList.remove('open')}
    });

    // Tab switching
    document.querySelectorAll('.hw-tab').forEach(tab=>{
      tab.addEventListener('click',()=>{
        const group=tab.closest('.hw-tab-group');
        group.querySelectorAll('.hw-tab').forEach(t=>t.classList.remove('active'));
        group.querySelectorAll('.hw-tab-content').forEach(c=>c.classList.remove('active'));
        tab.classList.add('active');
        document.getElementById(tab.dataset.tab).classList.add('active');
      });
    });

    // Copy code
    document.querySelectorAll('.hw-code-copy').forEach(btn=>{
      btn.addEventListener('click',()=>{
        const code=btn.closest('.hw-code-block').querySelector('code').textContent;
        navigator.clipboard.writeText(code);
        btn.textContent='Copied!';
        setTimeout(()=>btn.textContent='Copy',1500);
      });
    });

    // Copy page
    function copyPage(){
      const content=document.querySelector('.hw-main');
      if(content)navigator.clipboard.writeText(content.textContent.replace(/\s+/g,' ').trim());
    }

    // Dropdown toggle
    function toggleDropdown(id){
      document.querySelectorAll('.hw-dropdown').forEach(d=>{if(d.id!==id)d.classList.remove('open')});
      document.getElementById(id).classList.toggle('open');
    }
    document.addEventListener('click',e=>{
      if(!e.target.closest('.hw-copy-page-dropdown')){document.querySelectorAll('.hw-dropdown').forEach(d=>d.classList.remove('open'))}
    });

    // Search
    function filterComponents(q){
      const results=document.getElementById('search-results');
      if(!q){results.innerHTML='';return}
      const comps=<%= raw(PagesController::COMPONENTS.map{|k,v|{id:k,name:v["name"],cat:v["category"]}}.to_json) %>;
      const filtered=comps.filter(c=>c.name.toLowerCase().includes(q.toLowerCase())||c.id.includes(q.toLowerCase()));
      results.innerHTML=filtered.slice(0,15).map(c=>'<a href="/components/'+c.id+'" class="hw-search-result"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M13 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V9z"/><polyline points="13 2 13 9 20 9"/></svg><div><div class="name">'+c.name+'</div><div class="cat">'+c.cat+'</div></div></a>').join('');
    }
  </script>
</body>
</html>
