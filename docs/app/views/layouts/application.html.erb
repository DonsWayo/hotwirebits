<!DOCTYPE html>
<html lang="en" data-theme="dark">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>HotwireBits — UI Components for Rails</title>
    <meta name="description" content="240+ free UI components for Ruby on Rails. Tailwind CSS v4, Stimulus, Turbo.">
    <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🧱</text></svg>">
  <style>
    *{margin:0;padding:0;box-sizing:border-box}
    :root{
      --hw-bg:#09090b;--hw-fg:#fafafa;--hw-card:#0c0c0e;--hw-card-fg:#fafafa;
      --hw-primary:#fafafa;--hw-primary-fg:#18181b;--hw-secondary:#27272a;--hw-secondary-fg:#fafafa;
      --hw-muted:#27272a;--hw-muted-fg:#a1a1aa;--hw-border:#27272a;--hw-input:#27272a;
      --hw-ring:#fafafa;--hw-accent:#27272a;--hw-accent-fg:#fafafa;
      --hw-sidebar-w:280px;--hw-header-h:60px;
      --hw-success:#22c55e;--hw-warning:#eab308;--hw-info:#3b82f6;--hw-destructive:#ef4444;
    }
    [data-theme="light"]{
      --hw-bg:#ffffff;--hw-fg:#09090b;--hw-card:#ffffff;--hw-card-fg:#09090b;
      --hw-primary:#18181b;--hw-primary-fg:#fafafa;--hw-secondary:#f4f4f5;--hw-secondary-fg:#18181b;
      --hw-muted:#f4f4f5;--hw-muted-fg:#71717a;--hw-border:#e4e4e7;--hw-input:#e4e4e7;
      --hw-ring:#18181b;--hw-accent:#f4f4f5;--hw-accent-fg:#18181b;
    }
    body{font-family:-apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,"Helvetica Neue",sans-serif;background:var(--hw-bg);color:var(--hw-fg);line-height:1.6;font-size:15px;-webkit-font-smoothing:antialiased}
    a{color:inherit;text-decoration:none}
    code{font-family:"SF Mono",SFMono-Regular,Consolas,"Liberation Mono",Menlo,monospace;font-size:0.875em}
    ::selection{background:var(--hw-primary);color:var(--hw-primary-fg)}
    ::-webkit-scrollbar{width:6px;height:6px}
    ::-webkit-scrollbar-track{background:transparent}
    ::-webkit-scrollbar-thumb{background:var(--hw-border);border-radius:3px}

    /* Header */
    .hw-header{position:fixed;top:0;left:0;right:0;height:var(--hw-header-h);background:var(--hw-bg);border-bottom:1px solid var(--hw-border);display:flex;align-items:center;padding:0 1.5rem;z-index:50;gap:1rem;backdrop-filter:blur(8px)}
    .hw-header-logo{font-size:1.125rem;font-weight:700;display:flex;align-items:center;gap:0.5rem;white-space:nowrap}
    .hw-header-logo span{color:var(--hw-muted-fg);font-weight:400;font-size:0.8125rem}
    .hw-search-trigger{display:flex;align-items:center;gap:0.5rem;padding:0.5rem 1rem;border:1px solid var(--hw-border);border-radius:0.5rem;background:var(--hw-muted);color:var(--hw-muted-fg);font-size:0.875rem;cursor:pointer;flex:1;max-width:400px;transition:border-color 0.15s}
    .hw-search-trigger:hover{border-color:var(--hw-ring)}
    .hw-search-trigger kbd{font-size:0.6875rem;padding:0.125rem 0.375rem;border:1px solid var(--hw-border);border-radius:0.25rem;background:var(--hw-bg);margin-left:auto}
    .hw-header-actions{display:flex;align-items:center;gap:0.5rem;margin-left:auto}
    .hw-theme-toggle{width:36px;height:36px;border:1px solid var(--hw-border);border-radius:0.5rem;background:transparent;color:var(--hw-fg);cursor:pointer;display:flex;align-items:center;justify-content:center;transition:background 0.15s}
    .hw-theme-toggle:hover{background:var(--hw-accent)}

    /* Sidebar */
    .hw-sidebar{position:fixed;top:var(--hw-header-h);left:0;bottom:0;width:var(--hw-sidebar-w);border-right:1px solid var(--hw-border);padding:1.5rem 1rem;overflow-y:auto;background:var(--hw-bg);z-index:40}
    .hw-sidebar-section{margin-bottom:1.5rem}
    .hw-sidebar-title{font-size:0.6875rem;font-weight:600;text-transform:uppercase;letter-spacing:0.05em;color:var(--hw-muted-fg);margin-bottom:0.5rem;padding:0 0.75rem}
    .hw-sidebar-link{display:flex;align-items:center;gap:0.625rem;padding:0.4375rem 0.75rem;border-radius:0.375rem;font-size:0.875rem;color:var(--hw-muted-fg);transition:all 0.15s;cursor:pointer}
    .hw-sidebar-link:hover{color:var(--hw-fg);background:var(--hw-accent)}
    .hw-sidebar-link.active{color:var(--hw-fg);background:var(--hw-accent);font-weight:500}
    .hw-sidebar-icon{width:16px;height:16px;opacity:0.7}

    /* Main */
    .hw-main{margin-left:var(--hw-sidebar-w);margin-top:var(--hw-header-h);padding:2rem 3rem;max-width:960px}
    .hw-main-full{margin-left:var(--hw-sidebar-w);margin-top:var(--hw-header-h);padding:2rem 3rem}

    /* Breadcrumbs */
    .hw-breadcrumbs{display:flex;align-items:center;gap:0.375rem;font-size:0.8125rem;color:var(--hw-muted-fg);margin-bottom:1.5rem}
    .hw-breadcrumbs a{transition:color 0.15s}
    .hw-breadcrumbs a:hover{color:var(--hw-fg)}
    .hw-breadcrumbs .sep{color:var(--hw-border)}

    /* Typography */
    h1{font-size:2.25rem;font-weight:700;letter-spacing:-0.025em;margin-bottom:0.75rem;line-height:1.2}
    h2{font-size:1.5rem;font-weight:600;letter-spacing:-0.025em;margin-top:2.5rem;margin-bottom:1rem;line-height:1.3}
    h3{font-size:1.125rem;font-weight:600;margin-top:2rem;margin-bottom:0.75rem}
    p{color:var(--hw-muted-fg);margin-bottom:1rem;line-height:1.7}
    .hw-description{font-size:1.125rem;color:var(--hw-muted-fg);line-height:1.7;margin-bottom:2rem}

    /* Hero grid */
    .hw-hero-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1rem;margin:1.5rem 0 2.5rem}
    .hw-hero-card{border:1px solid var(--hw-border);border-radius:0.75rem;padding:1.25rem;transition:all 0.2s;background:var(--hw-card)}
    .hw-hero-card:hover{border-color:var(--hw-ring);transform:translateY(-1px)}
    .hw-hero-card h3{font-size:1rem;margin:0.5rem 0 0.25rem}
    .hw-hero-card p{font-size:0.8125rem;margin:0}
    .hw-hero-card .count{font-size:0.75rem;color:var(--hw-muted-fg);margin-top:0.5rem}
    .hw-hero-card-icon{width:36px;height:36px;border-radius:0.5rem;background:var(--hw-primary);color:var(--hw-primary-fg);display:flex;align-items:center;justify-content:center;font-size:1.125rem}

    /* Tabs */
    .hw-tabs{display:flex;gap:0;border-bottom:1px solid var(--hw-border);margin-bottom:1.5rem}
    .hw-tab{padding:0.75rem 1rem;font-size:0.875rem;font-weight:500;cursor:pointer;border-bottom:2px solid transparent;color:var(--hw-muted-fg);transition:all 0.15s;background:none;border-top:0;border-left:0;border-right:0}
    .hw-tab:hover{color:var(--hw-fg)}
    .hw-tab.active{color:var(--hw-fg);border-bottom-color:var(--hw-ring)}
    .hw-tab-content{display:none}
    .hw-tab-content.active{display:block}

    /* Preview box */
    .hw-preview{border:1px solid var(--hw-border);border-radius:0.75rem;padding:2rem;margin-bottom:1.5rem;background:var(--hw-card);min-height:120px;display:flex;align-items:center;justify-content:center;flex-direction:column;gap:1rem}
    .hw-preview-row{display:flex;align-items:center;gap:1rem;flex-wrap:wrap}
    .hw-preview-label{font-size:0.75rem;color:var(--hw-muted-fg);text-transform:uppercase;letter-spacing:0.05em;margin-bottom:0.5rem}

    /* Code blocks */
    .hw-code-block{position:relative;background:#1e1e2e;color:#cdd6f4;border-radius:0.75rem;margin-bottom:1.5rem;overflow:hidden}
    .hw-code-header{display:flex;align-items:center;justify-content:space-between;padding:0.5rem 1rem;border-bottom:1px solid #313244;font-size:0.75rem;color:#a6adc8}
    .hw-code-lang{padding:0.125rem 0.5rem;border-radius:0.25rem;background:#313244;font-size:0.6875rem;text-transform:uppercase}
    .hw-code-copy{padding:0.25rem 0.625rem;border-radius:0.375rem;background:#313244;color:#cdd6f4;border:none;cursor:pointer;font-size:0.75rem;transition:background 0.15s}
    .hw-code-copy:hover{background:#45475a}
    .hw-code-body{padding:1rem 1.25rem;overflow-x:auto;font-size:0.8125rem;line-height:1.7}
    .hw-code-body pre{margin:0}
    .hw-code-body .kw{color:#cba6f7}
    .hw-code-body .str{color:#a6e3a1}
    .hw-code-body .cmt{color:#6c7086}
    .hw-code-body .cls{color:#89dceb}
    .hw-code-body .sym{color:#f38ba8}
    .hw-code-body .num{color:#fab387}
    .hw-code-body .fn{color:#89b4fa}

    /* Props table */
    .hw-props-table{width:100%;border:1px solid var(--hw-border);border-radius:0.75rem;overflow:hidden;margin-bottom:2rem}
    .hw-props-table table{width:100%;border-collapse:collapse}
    .hw-props-table th{background:var(--hw-muted);padding:0.75rem 1rem;text-align:left;font-size:0.8125rem;font-weight:600;border-bottom:1px solid var(--hw-border)}
    .hw-props-table td{padding:0.625rem 1rem;font-size:0.8125rem;border-bottom:1px solid var(--hw-border)}
    .hw-props-table tr:last-child td{border-bottom:none}
    .hw-props-table code{background:var(--hw-muted);padding:0.125rem 0.375rem;border-radius:0.25rem;font-size:0.75rem}

    /* Callout */
    .hw-callout{border-radius:0.75rem;padding:1rem 1.25rem;margin-bottom:1.5rem;border:1px solid}
    .hw-callout-info{border-color:var(--hw-info);background:color-mix(in srgb, var(--hw-info) 10%, transparent)}
    .hw-callout-warning{border-color:var(--hw-warning);background:color-mix(in srgb, var(--hw-warning) 10%, transparent)}

    /* Component list */
    .hw-component-list{display:flex;flex-direction:column;gap:0.5rem}
    .hw-component-item{display:flex;align-items:center;justify-content:space-between;padding:0.875rem 1rem;border:1px solid var(--hw-border);border-radius:0.625rem;transition:all 0.15s;cursor:pointer}
    .hw-component-item:hover{border-color:var(--hw-ring);background:var(--hw-accent)}
    .hw-component-name{font-weight:500;font-size:0.9375rem}
    .hw-component-desc{font-size:0.8125rem;color:var(--hw-muted-fg);margin-top:0.125rem}
    .hw-component-arrow{color:var(--hw-muted-fg);font-size:0.875rem}

    /* Installation tabs */
    .hw-install-tabs{display:flex;gap:0;background:var(--hw-muted);border-radius:0.5rem 0.5rem 0 0;padding:0.25rem;width:fit-content}
    .hw-install-tab{padding:0.375rem 0.875rem;font-size:0.8125rem;border-radius:0.375rem;cursor:pointer;color:var(--hw-muted-fg);background:transparent;border:none;font-family:inherit}
    .hw-install-tab.active{background:var(--hw-bg);color:var(--hw-fg);box-shadow:0 1px 2px rgba(0,0,0,0.1)}

    /* Prev/Next nav */
    .hw-prev-next{display:flex;gap:1rem;margin-top:3rem;padding-top:2rem;border-top:1px solid var(--hw-border)}
    .hw-prev-next a{flex:1;padding:1rem;border:1px solid var(--hw-border);border-radius:0.75rem;transition:all 0.15s}
    .hw-prev-next a:hover{border-color:var(--hw-ring);background:var(--hw-accent)}
    .hw-prev-next .label{font-size:0.75rem;color:var(--hw-muted-fg);margin-bottom:0.25rem}
    .hw-prev-next .name{font-weight:500}

    /* Search modal */
    .hw-search-overlay{position:fixed;inset:0;background:rgba(0,0,0,0.6);z-index:100;display:none;align-items:flex-start;justify-content:center;padding-top:15vh;backdrop-filter:blur(4px)}
    .hw-search-overlay.open{display:flex}
    .hw-search-modal{background:var(--hw-bg);border:1px solid var(--hw-border);border-radius:0.75rem;width:100%;max-width:560px;max-height:480px;overflow:hidden;box-shadow:0 20px 60px rgba(0,0,0,0.4)}
    .hw-search-input{width:100%;padding:1rem 1.25rem;border:none;border-bottom:1px solid var(--hw-border);background:transparent;color:var(--hw-fg);font-size:1rem;outline:none}
    .hw-search-results{overflow-y:auto;max-height:400px;padding:0.5rem}
    .hw-search-result{display:block;padding:0.625rem 0.875rem;border-radius:0.5rem;cursor:pointer;transition:background 0.15s}
    .hw-search-result:hover{background:var(--hw-accent)}
    .hw-search-result .name{font-weight:500;font-size:0.875rem}
    .hw-search-result .cat{font-size:0.75rem;color:var(--hw-muted-fg)}

    /* Feature cards (Vercel style) */
    .hw-feature-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1rem;margin:1.5rem 0}
    .hw-feature-card{border:1px solid var(--hw-border);border-radius:0.75rem;padding:1.5rem;transition:all 0.2s;background:var(--hw-card)}
    .hw-feature-card:hover{border-color:var(--hw-ring)}
    .hw-feature-card h3{font-size:0.9375rem;margin:0.75rem 0 0.25rem}
    .hw-feature-card p{font-size:0.8125rem;margin:0;line-height:1.5}

    /* Badge */
    .hw-badge{display:inline-flex;padding:0.125rem 0.5rem;font-size:0.6875rem;font-weight:600;border-radius:9999px;background:var(--hw-muted);color:var(--hw-muted-fg)}

    /* Responsive */
    @media(max-width:1024px){
      .hw-hero-grid,.hw-feature-grid{grid-template-columns:repeat(2,1fr)}
    }
    @media(max-width:768px){
      .hw-sidebar{display:none}
      .hw-main,.hw-main-full{margin-left:0;padding:1rem}
      .hw-hero-grid,.hw-feature-grid{grid-template-columns:1fr}
      .hw-header{padding:0 1rem}
      .hw-search-trigger{max-width:none}
    }
  </style>
  <script>
    // Theme toggle
    (function(){
      const t=localStorage.getItem('hw-theme')||'dark';
      document.documentElement.setAttribute('data-theme',t);
    })();
  </script>
</head>
<body>
  <!-- Header -->
  <header class="hw-header">
    <a href="/" class="hw-header-logo">🧱 HotwireBits <span>Docs</span></a>
    <button class="hw-search-trigger" onclick="document.getElementById('search-overlay').classList.add('open');document.getElementById('search-input').focus()">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
