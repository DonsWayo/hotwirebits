<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>HotwireBits — UI Components for Rails</title>
    <meta name="description" content="240+ free UI components for Ruby on Rails. Tailwind CSS v4, Stimulus, Turbo.">
    <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><rect width='100' height='100' rx='20' fill='%2318181b'/><text x='50' y='68' text-anchor='middle' font-size='52' font-weight='bold' fill='white'>H</text></svg>">
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            'hw-background': 'var(--hw-bg)',
            'hw-foreground': 'var(--hw-fg)',
            'hw-primary': 'var(--hw-primary)',
            'hw-primary-foreground': 'var(--hw-primary-fg)',
            'hw-secondary': 'var(--hw-secondary)',
            'hw-secondary-foreground': 'var(--hw-secondary-fg)',
            'hw-muted': 'var(--hw-muted)',
            'hw-muted-foreground': 'var(--hw-muted-fg)',
            'hw-accent': 'var(--hw-accent)',
            'hw-accent-foreground': 'var(--hw-accent-fg)',
            'hw-border': 'var(--hw-border)',
            'hw-input': 'var(--hw-input)',
            'hw-ring': 'var(--hw-ring)',
            'hw-destructive': 'var(--hw-destructive)',
            'hw-success': 'var(--hw-success)',
            'hw-warning': 'var(--hw-warning)',
            'hw-info': 'var(--hw-info)',
            'hw-card': 'var(--hw-card)',
            'hw-card-foreground': 'var(--hw-card-fg)',
            'hw-popover': 'var(--hw-bg)',
            'hw-popover-foreground': 'var(--hw-fg)',
          }
        }
      }
    }
  </script>
  <style>
    *{margin:0;padding:0;box-sizing:border-box}
    :root{
      --hw-bg:#fff;--hw-fg:#09090b;--hw-card:#fff;--hw-card-fg:#09090b;
      --hw-primary:#18181b;--hw-primary-fg:#fafafa;--hw-secondary:#f4f4f5;--hw-secondary-fg:#18181b;
      --hw-muted:#f4f4f5;--hw-muted-fg:#52525b;--hw-border:#e4e4e7;--hw-input:#e4e4e7;
      --hw-ring:#18181b;--hw-accent:#f4f4f5;--hw-accent-fg:#18181b;
      --hw-sidebar-w:260px;--hw-header-h:56px;
      --hw-success:#16a34a;--hw-warning:#ca8a04;--hw-info:#2563eb;--hw-destructive:#dc2626;
    }
    @media(prefers-color-scheme:dark){
      :root{
        --hw-bg:#09090b;--hw-fg:#fafafa;--hw-card:#0c0c0e;--hw-card-fg:#fafafa;
        --hw-primary:#fafafa;--hw-primary-fg:#18181b;--hw-secondary:#1c1c1f;--hw-secondary-fg:#fafafa;
        --hw-muted:#1c1c1f;--hw-muted-fg:#a1a1aa;--hw-border:#27272a;--hw-input:#27272a;
        --hw-ring:#fafafa;--hw-accent:#1c1c1f;--hw-accent-fg:#fafafa;
        --hw-success:#22c55e;--hw-warning:#eab308;--hw-info:#3b82f6;--hw-destructive:#ef4444;
      }
    }
    body{font-family:-apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,sans-serif;background:var(--hw-bg);color:var(--hw-fg);line-height:1.6;font-size:15px;-webkit-font-smoothing:antialiased}
    a{color:inherit;text-decoration:none}
    code{font-family:"SF Mono",SFMono-Regular,Consolas,monospace;font-size:0.875em}
    ::selection{background:var(--hw-primary);color:var(--hw-primary-fg)}
    ::-webkit-scrollbar{width:5px;height:5px}
    ::-webkit-scrollbar-thumb{background:var(--hw-border);border-radius:9px}

    /* Header — Upstash style */
    .hw-header{position:fixed;top:0;left:0;right:0;height:var(--hw-header-h);background:var(--hw-bg);border-bottom:1px solid var(--hw-border);display:flex;align-items:center;padding:0 1.25rem;z-index:50;gap:1rem}
    .hw-header-logo{font-size:1rem;font-weight:700;display:flex;align-items:center;gap:0.5rem;white-space:nowrap;letter-spacing:-0.01em}
    .hw-header-logo svg{width:22px;height:22px;color:var(--hw-primary)}
    .hw-search-center{display:flex;align-items:center;flex:1;justify-content:center}
    .hw-search-bar{display:flex;align-items:center;gap:0.5rem;padding:0.375rem 0.875rem;border:1px solid var(--hw-border);border-radius:0.5rem;background:var(--hw-muted);color:var(--hw-muted-fg);font-size:0.8125rem;cursor:pointer;transition:border-color 0.15s;min-width:280px;max-width:420px;width:100%}
    .hw-search-bar:hover{border-color:var(--hw-ring)}
    .hw-search-bar svg{width:14px;height:14px;flex-shrink:0}
    .hw-search-bar span{flex:1;text-align:left}
    .hw-search-bar kbd{font-size:0.625rem;padding:0.125rem 0.375rem;border:1px solid var(--hw-border);border-radius:0.25rem;background:var(--hw-bg);margin-left:auto;font-family:inherit}
    .hw-header-right{display:flex;align-items:center;gap:0.375rem}
    .hw-icon-btn{width:32px;height:32px;border:1px solid var(--hw-border);border-radius:0.5rem;background:transparent;color:var(--hw-fg);cursor:pointer;display:flex;align-items:center;justify-content:center;transition:background 0.15s}
    .hw-icon-btn:hover{background:var(--hw-accent)}
    .hw-icon-btn svg{width:16px;height:16px}

    /* Sidebar */
    .hw-sidebar{position:fixed;top:var(--hw-header-h);left:0;bottom:0;width:var(--hw-sidebar-w);border-right:1px solid var(--hw-border);padding:1.25rem 0.75rem;overflow-y:auto;background:var(--hw-bg);z-index:40}
    .hw-sidebar-section{margin-bottom:1.25rem}
    .hw-sidebar-title{font-size:0.6875rem;font-weight:600;text-transform:uppercase;letter-spacing:0.05em;color:var(--hw-muted-fg);margin-bottom:0.375rem;padding:0 0.625rem}
    .hw-sidebar-link{display:flex;align-items:center;gap:0.5rem;padding:0.375rem 0.625rem;border-radius:0.375rem;font-size:0.8125rem;color:var(--hw-muted-fg);transition:all 0.15s;cursor:pointer}
    .hw-sidebar-link:hover{color:var(--hw-fg);background:var(--hw-accent)}
    .hw-sidebar-link.active{color:var(--hw-fg);background:var(--hw-accent);font-weight:500}
    .hw-sidebar-link svg{width:15px;height:15px;opacity:0.6;flex-shrink:0}

    /* Main */
    .hw-main{margin-left:var(--hw-sidebar-w);margin-top:var(--hw-header-h);padding:2rem 2.5rem;max-width:880px}

    /* Page title row — Upstash style */
    .hw-page-title-row{display:flex;align-items:center;gap:0.75rem;margin-bottom:0.5rem}
    .hw-page-title-row h1{font-size:1.75rem;font-weight:700;letter-spacing:-0.025em;margin:0;line-height:1.2}
    .hw-copy-page-btn{display:inline-flex;align-items:center;gap:0.375rem;padding:0.375rem 0.75rem;border:1px solid var(--hw-border);border-radius:0.5rem 0 0 0.5rem;background:transparent;color:var(--hw-muted-fg);font-size:0.75rem;cursor:pointer;transition:all 0.15s;font-family:inherit;white-space:nowrap}
    .hw-copy-page-btn:hover{background:var(--hw-accent);color:var(--hw-fg)}
    .hw-copy-page-btn svg{width:14px;height:14px}
    .hw-copy-page-dropdown{position:relative}
    .hw-copy-page-more{display:inline-flex;align-items:center;justify-content:center;padding:0.375rem 0.5rem;border:1px solid var(--hw-border);border-left:0;border-radius:0 0.5rem 0.5rem 0;background:transparent;color:var(--hw-muted-fg);cursor:pointer;transition:all 0.15s}
    .hw-copy-page-more:hover{background:var(--hw-accent);color:var(--hw-fg)}
    .hw-copy-page-more svg{width:10px;height:14px;transform:rotate(90deg)}
    .hw-page-desc{font-size:1.0625rem;color:var(--hw-muted-fg);line-height:1.7;margin-bottom:1.75rem}

    /* Breadcrumbs */
    .hw-breadcrumbs{display:flex;align-items:center;gap:0.375rem;font-size:0.75rem;color:var(--hw-muted-fg);margin-bottom:1rem}
    .hw-breadcrumbs a{transition:color 0.15s}
    .hw-breadcrumbs a:hover{color:var(--hw-fg)}
    .hw-breadcrumbs .sep{color:var(--hw-border)}

    /* Tabs — centered */
    .hw-tabs{display:flex;gap:0;border-bottom:1px solid var(--hw-border);margin-bottom:1.5rem}
    .hw-tab{padding:0.625rem 1rem;font-size:0.8125rem;font-weight:500;cursor:pointer;border-bottom:2px solid transparent;color:var(--hw-muted-fg);transition:all 0.15s;background:none;border-top:0;border-left:0;border-right:0;font-family:inherit}
    .hw-tab:hover{color:var(--hw-fg)}
    .hw-tab.active{color:var(--hw-fg);border-bottom-color:var(--hw-ring)}
    .hw-tab-content{display:none}
    .hw-tab-content.active{display:block}

    /* Preview */
    .hw-preview{border:1px solid var(--hw-border);border-radius:0.75rem;padding:2rem;margin-bottom:1.5rem;background:var(--hw-card);min-height:100px;display:flex;align-items:center;justify-content:center;flex-direction:column;gap:1rem}
    .hw-preview-row{display:flex;align-items:center;gap:1rem;flex-wrap:wrap}
    .hw-preview-label{font-size:0.6875rem;color:var(--hw-muted-fg);text-transform:uppercase;letter-spacing:0.05em;margin-bottom:0.375rem;font-weight:500}

    /* Code blocks */
    .hw-code-block{position:relative;background:#1e1e2e;color:#cdd6f4;border-radius:0.75rem;margin-bottom:1.5rem;overflow:hidden}
    .hw-code-header{display:flex;align-items:center;justify-content:space-between;padding:0.5rem 1rem;border-bottom:1px solid #313244;font-size:0.75rem;color:#a6adc8}
    .hw-code-lang{padding:0.125rem 0.5rem;border-radius:0.25rem;background:#313244;font-size:0.625rem;text-transform:uppercase;font-family:inherit}
    .hw-code-copy{padding:0.25rem 0.625rem;border-radius:0.375rem;background:#313244;color:#cdd6f4;border:none;cursor:pointer;font-size:0.6875rem;transition:background 0.15s;font-family:inherit}
    .hw-code-copy:hover{background:#45475a}
    .hw-code-body{padding:1rem 1.25rem;overflow-x:auto;font-size:0.8125rem;line-height:1.7}
    .hw-code-body pre{margin:0}
    .hw-code-body .kw{color:#cba6f7}
    .hw-code-body .str{color:#a6e3a1}
    .hw-code-body .cmt{color:#6c7086}
    .hw-code-body .cls{color:#89dceb}
    .hw-code-body .sym{color:#f38ba8}
    .hw-code-body .num{color:#fab387}
    .hw-code-body .fn{color:#89b4fa}

    /* Props table */
    .hw-props-table{width:100%;border:1px solid var(--hw-border);border-radius:0.75rem;overflow:hidden;margin-bottom:2rem}
    .hw-props-table table{width:100%;border-collapse:collapse}
    .hw-props-table th{background:var(--hw-muted);padding:0.625rem 1rem;text-align:left;font-size:0.75rem;font-weight:600;border-bottom:1px solid var(--hw-border)}
    .hw-props-table td{padding:0.5rem 1rem;font-size:0.8125rem;border-bottom:1px solid var(--hw-border)}
    .hw-props-table tr:last-child td{border-bottom:none}
    .hw-props-table code{background:var(--hw-muted);padding:0.0625rem 0.375rem;border-radius:0.25rem;font-size:0.75rem}

    /* Component list */
    .hw-component-list{display:flex;flex-direction:column;gap:0.375rem}
    .hw-component-item{display:flex;align-items:center;justify-content:space-between;padding:0.75rem 1rem;border:1px solid var(--hw-border);border-radius:0.625rem;transition:all 0.15s;cursor:pointer}
    .hw-component-item:hover{border-color:var(--hw-ring);background:var(--hw-accent)}
    .hw-component-name{font-weight:500;font-size:0.875rem}
    .hw-component-desc{font-size:0.75rem;color:var(--hw-muted-fg);margin-top:0.125rem}
    .hw-component-arrow{color:var(--hw-muted-fg);font-size:0.875rem}

    /* Feature cards */
    .hw-feature-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:0.75rem;margin:1.25rem 0 2rem}
    .hw-feature-card{border:1px solid var(--hw-border);border-radius:0.75rem;padding:1.25rem;transition:all 0.2s;background:var(--hw-card)}
    .hw-feature-card:hover{border-color:var(--hw-ring)}
    .hw-feature-card-icon{width:32px;height:32px;border-radius:0.5rem;background:var(--hw-primary);color:var(--hw-primary-fg);display:flex;align-items:center;justify-content:center;margin-bottom:0.75rem}
    .hw-feature-card-icon svg{width:16px;height:16px}
    .hw-feature-card h3{font-size:0.875rem;font-weight:600;margin-bottom:0.25rem}
    .hw-feature-card p{font-size:0.75rem;color:var(--hw-muted-fg);margin:0;line-height:1.5}

    /* Hero grid */
    .hw-hero-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:0.75rem;margin:1rem 0 2rem}
    .hw-hero-card{border:1px solid var(--hw-border);border-radius:0.625rem;padding:1rem;transition:all 0.2s;background:var(--hw-card)}
    .hw-hero-card:hover{border-color:var(--hw-ring);transform:translateY(-1px)}
    .hw-hero-card h3{font-size:0.875rem;font-weight:600;margin-bottom:0.125rem}
    .hw-hero-card .count{font-size:0.6875rem;color:var(--hw-muted-fg)}

    /* Install tabs */
    .hw-install-tabs{display:flex;gap:0;background:var(--hw-muted);border-radius:0.5rem 0.5rem 0 0;padding:0.1875rem;width:fit-content}
    .hw-install-tab{padding:0.3125rem 0.75rem;font-size:0.75rem;border-radius:0.375rem;cursor:pointer;color:var(--hw-muted-fg);background:transparent;border:none;font-family:inherit}
    .hw-install-tab.active{background:var(--hw-bg);color:var(--hw-fg);box-shadow:0 1px 2px rgba(0,0,0,0.08)}

    /* Prev/Next */
    .hw-prev-next{display:flex;gap:0.75rem;margin-top:2.5rem;padding-top:1.5rem;border-top:1px solid var(--hw-border)}
    .hw-prev-next a{flex:1;padding:0.875rem;border:1px solid var(--hw-border);border-radius:0.625rem;transition:all 0.15s}
    .hw-prev-next a:hover{border-color:var(--hw-ring);background:var(--hw-accent)}
    .hw-prev-next .label{font-size:0.6875rem;color:var(--hw-muted-fg);margin-bottom:0.125rem}
    .hw-prev-next .name{font-weight:500;font-size:0.875rem}

    /* Search modal */
    .hw-search-overlay{position:fixed;inset:0;background:rgba(0,0,0,0.5);z-index:100;display:none;align-items:flex-start;justify-content:center;padding-top:12vh;backdrop-filter:blur(4px)}
    .hw-search-overlay.open{display:flex}
    .hw-search-modal{background:var(--hw-bg);border:1px solid var(--hw-border);border-radius:0.75rem;width:100%;max-width:520px;max-height:420px;overflow:hidden;box-shadow:0 20px 60px rgba(0,0,0,0.3)}
    .hw-search-input{width:100%;padding:0.875rem 1rem;border:none;border-bottom:1px solid var(--hw-border);background:transparent;color:var(--hw-fg);font-size:0.9375rem;outline:none;font-family:inherit}
    .hw-search-input::placeholder{color:var(--hw-muted-fg)}
    .hw-search-results{overflow-y:auto;max-height:350px;padding:0.375rem}
    .hw-search-result{display:flex;align-items:center;gap:0.625rem;padding:0.5rem 0.75rem;border-radius:0.5rem;cursor:pointer;transition:background 0.15s}
    .hw-search-result:hover{background:var(--hw-accent)}
    .hw-search-result .name{font-weight:500;font-size:0.8125rem}
    .hw-search-result .cat{font-size:0.6875rem;color:var(--hw-muted-fg)}
    .hw-search-result svg{width:14px;height:14px;color:var(--hw-muted-fg);flex-shrink:0}

    /* Badge */
    .hw-badge{display:inline-flex;padding:0.125rem 0.4375rem;font-size:0.625rem;font-weight:600;border-radius:9999px;background:var(--hw-muted);color:var(--hw-muted-fg)}

    /* Preview boxes */
    .hw-preview-box{border:1px solid var(--hw-border);border-radius:0.75rem;padding:1.5rem;margin-bottom:1.5rem;background:var(--hw-card)}
    .hw-preview-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:1rem}
    .hw-preview-card{border:1px solid var(--hw-border);border-radius:0.625rem;overflow:hidden;background:var(--hw-bg)}
    .hw-preview-card-label{padding:0.5rem 0.75rem;font-size:0.6875rem;font-weight:600;text-transform:uppercase;letter-spacing:0.05em;color:var(--hw-muted-fg);border-bottom:1px solid var(--hw-border);background:var(--hw-muted)}
    .hw-preview-card-body{padding:1.25rem;display:flex;align-items:center;justify-content:center;min-height:80px}
    .hw-install-group{margin-bottom:1.5rem}

    /* Callout */
    .hw-callout{border-radius:0.625rem;padding:0.875rem 1rem;margin-bottom:1.25rem;border:1px solid;font-size:0.8125rem}
    .hw-callout-info{border-color:var(--hw-info);background:color-mix(in srgb,var(--hw-info) 8%,transparent)}
    .hw-callout-warning{border-color:var(--hw-warning);background:color-mix(in srgb,var(--hw-warning) 8%,transparent)}

    /* Dropdown menu */
    .hw-dropdown{position:absolute;top:100%;right:0;background:var(--hw-bg);border:1px solid var(--hw-border);border-radius:0.625rem;padding:0.25rem;min-width:200px;box-shadow:0 10px 40px rgba(0,0,0,0.15);z-index:60;display:none}
    .hw-dropdown.open{display:block}
    .hw-dropdown-item{display:flex;align-items:center;gap:0.625rem;padding:0.5rem 0.625rem;border-radius:0.375rem;font-size:0.8125rem;color:var(--hw-muted-fg);cursor:pointer;transition:all 0.15s}
    .hw-dropdown-item:hover{background:var(--hw-accent);color:var(--hw-fg)}
    .hw-dropdown-item svg{width:14px;height:14px;flex-shrink:0;opacity:0.6}

    /* Responsive */
    @media(max-width:1024px){.hw-hero-grid,.hw-feature-grid{grid-template-columns:repeat(2,1fr)}}
    @media(max-width:768px){
      .hw-sidebar{display:none}
      .hw-main{margin-left:0;padding:1.25rem 1rem}
      .hw-hero-grid,.hw-feature-grid{grid-template-columns:1fr}
      .hw-search-center{display:none}
    }
  </style>
</head>
<body>
  <!-- Header -->
  <header class="hw-header">
    <a href="/" class="hw-header-logo">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg>
      HotwireBits
    </a>
    <div class="hw-search-center">
      <button class="hw-search-bar" onclick="document.getElementById('search-overlay').classList.add('open');document.getElementById('search-input').focus()">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
        <span>Search documentation...</span>
        <kbd>⌘K</kbd>
      </button>
    </div>
    <div class="hw-header-right">
      <button class="hw-icon-btn" onclick="toggleTheme()" title="Toggle theme">
        <svg class="theme-light" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="5"/><path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/></svg>
      </button>
      <a href="https://github.com/hotwirebits/hotwirebits" class="hw-icon-btn" title="GitHub" target="_blank">
        <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
      </a>
    </div>
  </header>
  <!-- Search Modal -->
  <div id="search-overlay" class="hw-search-overlay" onclick="if(event.target===this)this.classList.remove('open')">
    <div class="hw-search-modal">
      <input id="search-input" class="hw-search-input" type="text" placeholder="Search components..." oninput="filterComponents(this.value)">
      <div id="search-results" class="hw-search-results"></div>
    </div>
  </div>
  <!-- Sidebar -->
  <nav class="hw-sidebar">
    <div class="hw-sidebar-section">
      <a href="/" class="hw-sidebar-link">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><path d="M9 22V12h6v10"/></svg>
        Getting Started
      </a>
    </div>
