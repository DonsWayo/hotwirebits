  <!-- Main -->
  <main class="hw-main">
    <%= yield %>
  </main>
  <script>
    // Theme toggle
    function toggleTheme(){
      const h=document.documentElement;
      const c=h.getAttribute('data-theme')==='dark'?'light':'dark';
      h.setAttribute('data-theme',c);
      localStorage.setItem('hw-theme',c);
    }

    // Keyboard shortcuts
    document.addEventListener('keydown',e=>{
      if((e.metaKey||e.ctrlKey)&&e.key==='k'){
        e.preventDefault();
        document.getElementById('search-overlay').classList.toggle('open');
        if(document.getElementById('search-overlay').classList.contains('open')){
          document.getElementById('search-input').focus();
        }
      }
      if(e.key==='Escape'){
        document.getElementById('search-overlay').classList.remove('open');
      }
    });

    // Tab switching
    document.querySelectorAll('.hw-tab').forEach(tab=>{
      tab.addEventListener('click',()=>{
        const group=tab.closest('.hw-tab-group');
        group.querySelectorAll('.hw-tab').forEach(t=>t.classList.remove('active'));
        group.querySelectorAll('.hw-tab-content').forEach(c=>c.classList.remove('active'));
        tab.classList.add('active');
        document.getElementById(tab.dataset.tab).classList.add('active');
      });
    });

    // Copy code
    document.querySelectorAll('.hw-code-copy').forEach(btn=>{
      btn.addEventListener('click',()=>{
        const code=btn.closest('.hw-code-block').querySelector('code').textContent;
        navigator.clipboard.writeText(code);
        btn.textContent='Copied!';
        setTimeout(()=>btn.textContent='Copy',1500);
      });
    });

    // Search filter
    function filterComponents(q){
      const results=document.getElementById('search-results');
      if(!q){results.innerHTML='';return;}
      const comps=<%= raw(PagesController::COMPONENTS.map{|k,v|{id:k,name:v["name"],cat:v["category"]}}.to_json) %>;
      const filtered=comps.filter(c=>c.name.toLowerCase().includes(q.toLowerCase())||c.id.includes(q.toLowerCase()));
      results.innerHTML=filtered.slice(0,20).map(c=>'<a href="/components/'+c.id+'" class="hw-search-result"><div class="name">'+c.name+'</div><div class="cat">'+c.cat+'</div></a>').join('');
    }
  </script>
</body>
</html>
